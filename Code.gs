function ensureSheet_(table) {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sh = ss.getSheetByName(table);
  if (!sh) sh = ss.insertSheet(table);
  var wanted = SCHEMA[table] || [];
  if (!wanted.length) throw new Error('Unknown table: ' + table);

  var current = [];
  if (sh.getLastRow() >= 1 && sh.getLastColumn() >= 1) {
    current = sh.getRange(1,1,1,sh.getLastColumn()).getDisplayValues()[0]
      .map(function(x){ return String(x || '').trim(); })
      .filter(Boolean);
  }
  if (!current.length) {
    sh.getRange(1,1,1,wanted.length).setValues([wanted]);
  } else {
    var add = wanted.filter(function(h){ return current.indexOf(h) < 0; });
    if (add.length) sh.getRange(1, current.length + 1, 1, add.length).setValues([add]);
  }

  try {
    sh.setFrozenRows(1);
    sh.getRange(1,1,1,Math.max(sh.getLastColumn(), wanted.length))
      .setBackground('#244963')
      .setFontColor('#FFFFFF')
      .setFontWeight('bold')
      .setHorizontalAlignment('center')
      .setVerticalAlignment('middle')
      .setWrap(true);
    sh.autoResizeColumns(1, Math.min(sh.getLastColumn(), 20));
  } catch(e) {}
  return sh;
}

function formatAllSheetsLegacy_() {
  Object.keys(SCHEMA).forEach(function(t) {
    var sh = SpreadsheetApp.getActiveSpreadsheet().getSheetByName(t);
    if (!sh) return;
    var h = headers_(t);
    try {
      for (var i = 0; i < h.length; i++) {
        var w = 145;
        if (['FieldsJson','DataJson','BeforeJson','AfterJson','RecordJson','Description','Remarks','ClientComment','ReviewComment'].indexOf(h[i]) >= 0) w = 340;
        if (['DocumentTitle','TemplateName','ProjectName','Title'].indexOf(h[i]) >= 0) w = 240;
        if (/Date$|At$/.test(h[i])) w = 130;
        sh.setColumnWidth(i+1, w);
      }
      if (sh.getMaxRows() > 1) sh.getRange(2,1,sh.getMaxRows()-1,Math.max(1,sh.getLastColumn())).setWrap(true).setVerticalAlignment('middle');
    } catch(e) {}
  });
}

