function nextIssueNo_(projectCode, templateCode) {
  var rows = [];
  try { rows = readRows_('FORM_RECORDS', {projectCode:projectCode, includeDeleted:false, maxRows:5000}); } catch(e) { rows = []; }
  var max = 0;
  rows.forEach(function(r){
    if (String(r.TemplateCode || '') !== String(templateCode || '')) return;
    var a = parseInt(String(r.IssueNo || '').replace(/[^0-9]/g, ''), 10);
    if (!isNaN(a)) max = Math.max(max, a);
    var m = String(r.DocumentNo || '').match(/-(\d{3,})$/);
    if (m) max = Math.max(max, parseInt(m[1], 10) || 0);
  });
  try {
    var docs = readRows_('DOCUMENT_REGISTER', {projectCode:projectCode, includeDeleted:false, maxRows:5000});
    var docCode = docCodeForTemplate_(v9DefaultTemplate_(templateCode) || {TemplateCode:templateCode});
    docs.forEach(function(d){
      if (String(d.DocumentCode || '') !== String(docCode || '')) return;
      var m = String(d.DocumentId || d.DocumentNo || d.FileUrl || '').match(/-(\d{3,})$/);
      if (m) max = Math.max(max, parseInt(m[1], 10) || 0);
      var s = parseInt(String(d.SubmissionNo || '').replace(/[^0-9]/g, ''), 10);
      if (!isNaN(s)) max = Math.max(max, s);
    });
  } catch(e2) {}
  return String(max + 1).padStart(3, '0');
}

function v9DefaultTemplate_(templateCode) {
  try {
    if (typeof DEFAULT_FORM_TEMPLATES !== 'undefined') {
      for (var i = 0; i < DEFAULT_FORM_TEMPLATES.length; i++) {
        if (String(DEFAULT_FORM_TEMPLATES[i].TemplateCode || '') === String(templateCode || '')) return DEFAULT_FORM_TEMPLATES[i];
      }
    }
  } catch(e) {}
  if (templateCode === 'PJ-WCR-001') return {TemplateCode:'PJ-WCR-001', TemplateName:'Work Completion Report', Module:'Handover / Closure', PhaseNo:'7', DocCategory:'Post-construction'};
  if (templateCode === 'PJ-EQUIP-CHK-001') return {TemplateCode:'PJ-EQUIP-CHK-001', TemplateName:'Equipment Checklist', Module:'Installation', PhaseNo:'4', DocCategory:'Construction'};
  return null;
}

function v9GetProjectSafe_(projectCode) {
  try {
