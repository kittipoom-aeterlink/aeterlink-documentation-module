function dmsV3DateLong_(v) {
  if (!v) return todayLong_();
  var s = String(v || '').trim();
  var m = s.match(/^(\d{4})-(\d{2})-(\d{2})$/);
  if (m) return Number(m[3]) + ' ' + ['','January','February','March','April','May','June','July','August','September','October','November','December'][Number(m[2])] + ' ' + m[1];
  m = s.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);
  if (m) return Number(m[1]) + ' ' + ['','January','February','March','April','May','June','July','August','September','October','November','December'][Number(m[2])] + ' ' + m[3];
  return s;
}

