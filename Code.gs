function renderA4Html_(tpl, project, data, options) {
  options = options || {};
  data = normalizeDocData_(tpl, project, data || {}, options.record || {});
  if (tpl.TemplateCode === 'PJ-EQUIP-CHK-001') return renderEquipmentChecklistDocumentV3_(tpl, project, data, options);
  if (tpl.TemplateCode === 'PJ-WCR-001' || /work completion/i.test(String(tpl.TemplateName || ''))) return renderWorkCompletionReportDocumentV3_(tpl, project, data, options);
  var title = String(tpl.TemplateName || '').replace(/Equipment Check List/g, 'Equipment Checklist').toUpperCase();
  return '<div class="a4-root">' + dmsV3PageStyle_() + '<div class="a4-page">' + renderDocHeader_(title, tpl, project, data, options, 1, 1) + renderGenericForm_(tpl, project, data, options) + renderFooter_(data, 1, 1) + '</div></div>';
}

function renderDocHeader_(title, tpl, project, data, options, pageNo, totalPages, continued) {
  project = project || {};
  tpl = tpl || {};
  data = data || {};
  var docNo = data.DocumentNo || 'Not issued – suffix XXX';
  var rev = data.RevisionNo || '00';
  var date = dmsV3DateLong_(data.Date || data.InspectionDate || data.CompletionDate || todayLong_());
  return '' +
    '<div class="doc-head">' +
      '<div class="logo-box"><img src="' + DMS_V3_LOGO_URI + '" alt="AETERLINK"></div>' +
      '<div class="title-box"><h1>' + esc_(title) + '</h1><p>' + esc_(continued ? moduleSubtitle_(tpl) + ' · Continued' : moduleSubtitle_(tpl)) + '</p></div>' +
      '<div class="meta-box">' +
        '<div class="meta-line"><b>Doc No.:</b><span class="meta-val">' + inlineField_('DocumentNo', docNo, options, 'left') + '</span></div>' +
        '<div class="meta-line"><b>Rev.:</b><span class="meta-val">' + inlineField_('RevisionNo', rev, options, 'left') + '</span></div>' +
        '<div class="meta-line"><b>Date:</b><span class="meta-val">' + inlineField_('Date', date, options, 'left') + '</span></div>' +
      '</div>' +
    '</div>' +
    '<div class="info-grid">' +
      infoCell_('Project Code', 'ProjectCode', data.ProjectCode || project.ProjectCode || '', options) +
      infoCell_('Project Name / Site', 'ProjectName', data.ProjectName || data.ProjectNameSite || project.ProjectName || '', options) +
      infoCell_('Client', 'ClientName', data.ClientName || data.Client || project.Client || '', options) +
      infoCell_('Main-Contractor', 'MainContractor', data.MainContractor || project.MainContractor || getSetting_('MAIN_CONTRACTOR_DEFAULT') || '', options) +
    '</div>';
}

function renderFooter_(data, pageNo, totalPages) {
  return '<div class="foot">Doc No. ' + esc_(data.DocumentNo || 'Not issued') + ' · Page ' + (pageNo || 1) + ' / ' + (totalPages || 1) + '</div>';
}

function renderEquipmentChecklistDocumentV3_(tpl, project, data, options) {
  var rows = parseEqTableRowsV3_(data.AdvancedTableJson);
  if (!rows.length) rows = DEFAULT_EQUIPMENT_ROWS;
  rows = rows.map(function(r, i) { r.No = r.No || String(i+1); return r; });
  var firstRows = 16, nextRows = 22;
  var tablePages = [];
  tablePages.push({start:0,count:firstRows,first:true});
  var cursor = firstRows;
  while (cursor < rows.length) { tablePages.push({start:cursor,count:nextRows,first:false}); cursor += nextRows; }
  var totalPages = tablePages.length + 1;
  var html = '<div class="a4-root">' + dmsV3PageStyle_();
  for (var p=0; p<tablePages.length; p++) {
    var pg = tablePages[p];
    html += '<div class="a4-page">' + renderDocHeader_('EQUIPMENT CHECKLIST', tpl, project, data, options, p+1, totalPages, !pg.first);
    if (pg.first) {
      html += '<div class="section-title">DOCUMENT INFORMATION</div>' +
        '<table class="box-table"><tr><th>Drawing References</th></tr><tr><td>' + fieldInput_('DrawingRef', data.DrawingRef || 'As-built drawings / installed location', options, 'textarea', 'left') + '</td></tr>' +
        '<tr><th>Reference Documents</th></tr><tr><td>' + fieldInput_('ReferenceDocument', data.ReferenceDocument || '20260423 Equipment Checklist Lotus — Niagara & AirPlug', options, 'textarea', 'left') + '</td></tr></table>' +
        '<div class="section-title">EQUIPMENT CHECKLIST</div>';
    } else {
      html += '<div class="section-title">EQUIPMENT CHECKLIST — CONTINUED</div>';
    }
    html += renderEqTableV3_(rows, pg.start, pg.count, options) + renderFooter_(data, p+1, totalPages) + '</div>';
  }
  html += '<div class="a4-page">' + renderDocHeader_('EQUIPMENT CHECKLIST', tpl, project, data, options, totalPages, totalPages, true) + renderEqSummaryV3_(data, rows, options) + renderSignatureBlock_(options) + renderFooter_(data, totalPages, totalPages) + '</div></div>';
  return html;
}

function parseEqTableRowsV3_(raw) {
  var parsed = parseJson_(raw, null);
  if (Array.isArray(parsed)) return parsed;
  if (parsed && Array.isArray(parsed.rows)) return parsed.rows;
  return [];
}

function renderEqTableV3_(rows, start, count, options) {
  var part = rows.slice(start, start + count);
  var html = '<table class="a4-table eq-table"><thead><tr>' +
    '<th style="width:4%">No.</th><th style="width:17%">Item description</th><th style="width:8%">Brand</th><th style="width:12%">Product name</th><th style="width:7%">Installed<br>Qty</th><th style="width:10%">Localisation</th><th style="width:5%">Floor</th><th style="width:10%">Position<br>(As-built)</th><th style="width:10%">Condition<br>(no risk)</th><th style="width:10%">Power-on<br>Confirm</th><th style="width:9%">Remarks</th>' +
    (options.editable ? '<th class="print-hidden" style="width:7%">Action</th>' : '') + '</tr></thead><tbody>';
  part.forEach(function(r, j) {
    var i = start + j;
    html += '<tr data-array-row="AdvancedTableJson" data-index="' + i + '">' +
      '<td>' + (i + 1) + '</td>' +
      eqCell_(i,'ItemDescription',r.ItemDescription,options,'center') +
      eqCell_(i,'Brand',r.Brand,options,'center') +
      eqCell_(i,'ProductName',r.ProductName,options,'center') +
      eqCell_(i,'InstalledQuantity',r.InstalledQuantity,options,'center') +
      eqCell_(i,'Localisation',r.Localisation,options,'center') +
      eqCell_(i,'Floor',r.Floor,options,'center') +
      eqCell_(i,'InstallationPosition',r.InstallationPosition,options,'center') +
      eqCell_(i,'InstallationCondition',r.InstallationCondition,options,'center') +
      eqCell_(i,'PowerOnConfirmation',r.PowerOnConfirmation,options,'center') +
      eqCell_(i,'Remarks',r.Remarks,options,'center') +
      (options.editable ? '<td class="row-actions print-hidden"><button onclick="a4AddRow(&quot;AdvancedTableJson&quot;,' + i + ')">＋</button><button onclick="a4DeleteRow(&quot;AdvancedTableJson&quot;,' + i + ')">−</button><button onclick="a4MoveRow(&quot;AdvancedTableJson&quot;,' + i + ',-1)">↑</button><button onclick="a4MoveRow(&quot;AdvancedTableJson&quot;,' + i + ',1)">↓</button></td>' : '') +
    '</tr>';
  });
  return html + '</tbody></table>';
}

function renderEqSummaryV3_(data, rows, options) {
  var checked = rows.filter(function(r){return String(r.InstallationPosition||'').toUpperCase()==='OK' || String(r.PowerOnConfirmation||'').toUpperCase()==='OK';}).length;
  return '<div class="section-title">SUMMARY / STATUS</div>' +
    '<table class="box-table"><tr><th>Total Listed</th><th>Total Checked</th><th>Total Accepted</th><th>Open Item Count</th></tr>' +
    '<tr><td>' + fieldInput_('TotalListed', data.TotalListed || String(rows.length), options, 'text', 'center') + '</td><td>' + fieldInput_('TotalChecked', data.TotalChecked || String(checked || rows.length), options, 'text', 'center') + '</td><td>' + fieldInput_('TotalAccepted', data.TotalAccepted || String(rows.length), options, 'text', 'center') + '</td><td>' + fieldInput_('OpenItemCount', data.OpenItemCount || '0', options, 'text', 'center') + '</td></tr>' +
    '<tr><th colspan="4">General Remarks</th></tr><tr><td colspan="4">' + fieldInput_('GeneralRemarks', data.GeneralRemarks || 'Real equipment checklist data imported from uploaded Excel file.', options, 'textarea', 'left') + '</td></tr></table>';
}

function renderWorkCompletionReportDocumentV3_(tpl, project, data, options) {
  var work = parseArray_(data.WorkItemsJson || data.WorkItems, DEFAULT_WCR_WORK_ITEMS);
  var photos = parseArray_(data.PhotoItemsJson || data.PhotoItems, DEFAULT_WCR_PHOTO_ITEMS);
  if (!work.length) work = DEFAULT_WCR_WORK_ITEMS;
  if (!photos.length) photos = DEFAULT_WCR_PHOTO_ITEMS;
  var firstRows = 18, nextRows = 28, photoPerPage = 2;
  var workPageCount = 1 + Math.max(0, Math.ceil(Math.max(0, work.length-firstRows)/nextRows));
  var photoPageCount = Math.max(1, Math.ceil(photos.length/photoPerPage));
  var totalPages = workPageCount + photoPageCount + 1;
  var html = '<div class="a4-root">' + dmsV3PageStyle_();
  var page = 1;
  html += '<div class="a4-page">' + renderDocHeader_('WORK COMPLETION REPORT', tpl, project, data, options, page, totalPages, false) + renderWcrInfoV3_(data, options) + '<div class="section-title">SCOPE OF WORK — COMPLETION STATUS</div>' + renderWcrTableV3_(work,0,firstRows,options) + renderFooter_(data,page,totalPages) + '</div>';
  page++;
  var cursor = firstRows;
  while (cursor < work.length) {
    html += '<div class="a4-page">' + renderDocHeader_('WORK COMPLETION REPORT', tpl, project, data, options, page, totalPages, true) + '<div class="section-title">SCOPE OF WORK — CONTINUED</div>' + renderWcrTableV3_(work,cursor,nextRows,options) + renderFooter_(data,page,totalPages) + '</div>';
    cursor += nextRows; page++;
  }
  for (var ps=0; ps<photos.length || (ps===0 && photos.length===0); ps += photoPerPage) {
    html += '<div class="a4-page">' + renderDocHeader_('WORK COMPLETION REPORT', tpl, project, data, options, page, totalPages, true) + '<div class="section-title">PHOTO EVIDENCE</div>' + renderWcrPhotoGridV3_(photos, ps, photoPerPage, options) + renderFooter_(data,page,totalPages) + '</div>';
    page++;
  }
  html += '<div class="a4-page">' + renderDocHeader_('WORK COMPLETION REPORT', tpl, project, data, options, page, totalPages, true) + '<div class="section-title">COMPLETION CERTIFICATION</div><table class="box-table"><tr><td>This Work Completion Report is certified by the parties listed below. The completed works, supporting documents, and photo evidence have been reviewed as applicable.</td></tr></table>' + renderSignatureBlock_(options) + renderFooter_(data,page,totalPages) + '</div></div>';
  return html;
}

function renderWcrInfoV3_(data, options) {
  return '<div class="section-title">DOCUMENT INFORMATION</div>' +
    '<table class="box-table"><tr><th>Branch / Location</th><th>Purchase Order No.</th><th>Contract No.</th></tr>' +
    '<tr><td>' + fieldInput_('BranchLocation', data.BranchLocation || 'Lotus’s Klong Luang', options, 'text', 'left') + '</td><td>' + fieldInput_('PurchaseOrderNo', data.PurchaseOrderNo || 'Vol. no.075, No.3739 / 3741 / 3746 / 3743', options, 'text', 'left') + '</td><td>' + fieldInput_('ContractNo', data.ContractNo || '-', options, 'text', 'left') + '</td></tr>' +
    '<tr><th colspan="3">Work Type</th></tr><tr><td colspan="3">' + fieldInput_('WorkType', data.WorkType || 'Equipment Purchasing / Installation / Implementation / BMS & BEMS Development', options, 'text', 'left') + '</td></tr>' +
    '<tr><th colspan="3">Reference Documents</th></tr><tr><td colspan="3">' + fieldInput_('ReferenceDocument', data.ReferenceDocument || 'Lotus Work Completion Report.xlsx — CoverPage / Photo Report / Gantt Chart', options, 'textarea', 'left') + '</td></tr>' +
    '<tr><th colspan="3">Remarks / Additional Notes</th></tr><tr><td colspan="3">' + fieldInput_('Remarks', data.Remarks || 'Work completion report data prepared from uploaded Lotus Work Completion Report workbook.', options, 'textarea', 'left') + '</td></tr></table>';
}

function renderWcrTableV3_(work, start, count, options) {
  var part = work.slice(start, start+count);
  var html = '<table class="a4-table wcr-table"><thead><tr><th style="width:13%">Package</th><th style="width:8%">Item</th><th>Work Description</th><th style="width:8%">Qty</th><th style="width:8%">Unit</th><th style="width:12%">Status</th><th style="width:15%">Remarks</th>' + (options.editable ? '<th class="print-hidden" style="width:8%">Action</th>' : '') + '</tr></thead><tbody>';
  part.forEach(function(r,j) { var i=start+j; html += '<tr data-array-row="WorkItemsJson" data-index="' + i + '">' + wcrCell_(i,'Package',r.Package,options,'center') + wcrCell_(i,'Item',r.Item,options,'center') + wcrCell_(i,'WorkDescription',r.WorkDescription,options,'left') + wcrCell_(i,'Qty',r.Qty,options,'center') + wcrCell_(i,'Unit',r.Unit,options,'center') + wcrCell_(i,'Status',r.Status,options,'center') + wcrCell_(i,'Remarks',r.Remarks,options,'left') + (options.editable ? '<td class="row-actions print-hidden"><button onclick="a4AddRow(&quot;WorkItemsJson&quot;,' + i + ')">＋</button><button onclick="a4DeleteRow(&quot;WorkItemsJson&quot;,' + i + ')">−</button><button onclick="a4MoveRow(&quot;WorkItemsJson&quot;,' + i + ',-1)">↑</button><button onclick="a4MoveRow(&quot;WorkItemsJson&quot;,' + i + ',1)">↓</button></td>' : '') + '</tr>'; });
  return html + '</tbody></table>';
}

function renderWcrPhotoGridV3_(photos, start, count, options) {
  var part = photos.slice(start, start+count);
  while (part.length < count) part.push({ItemNo:'',Description:'',Note:'',ImageKey:''});
  var html = '<div class="photo-grid">';
  part.forEach(function(p,j) {
    var i=start+j;
    var src = p.ImageData || (p.ImageKey && DMS_V3_WCR_IMAGE_MAP[p.ImageKey]) || '';
    html += '<div class="photo-card" data-array-row="PhotoItemsJson" data-index="' + i + '">' +
      (options.editable ? '<input type="hidden" data-array="PhotoItemsJson" data-index="' + i + '" data-key="ImageKey" value="' + escAttr_(p.ImageKey || '') + '"><input type="hidden" data-array="PhotoItemsJson" data-index="' + i + '" data-key="ImageData" value="' + escAttr_(p.ImageData || '') + '">' : '') +
      '<div class="photo-box">' + (src ? '<img src="' + escAttr_(src) + '">' : 'PHOTO AREA<br><span>Insert image in A4 preview</span>') + '</div>' +
      '<table class="box-table"><tr><th style="width:25%">Item No.</th><td>' + photoFieldV3_(i,'ItemNo',p.ItemNo,options,'text') + '</td></tr>' +
      '<tr class="ruled"><th>Description</th><td>' + photoFieldV3_(i,'Description',p.Description,options,'textarea') + '</td></tr>' +
      '<tr class="ruled"><th>Note</th><td>' + photoFieldV3_(i,'Note',p.Note,options,'textarea') + '</td></tr></table>' +
      (options.editable ? '<div class="row-actions print-hidden"><button onclick="a4AddRow(&quot;PhotoItemsJson&quot;,' + i + ')">＋ Add Photo</button><button onclick="a4DeleteRow(&quot;PhotoItemsJson&quot;,' + i + ')">− Delete</button><button onclick="a4MoveRow(&quot;PhotoItemsJson&quot;,' + i + ',-1)">↑</button><button onclick="a4MoveRow(&quot;PhotoItemsJson&quot;,' + i + ',1)">↓</button></div>' : '') +
    '</div>';
  });
  return html + '</div>';
}

function photoFieldV3_(i, key, value, options, type) {
  if (!options.editable) return esc_(value || '');
  if (type === 'textarea') return '<textarea data-array="PhotoItemsJson" data-index="' + i + '" data-key="' + escAttr_(key) + '">' + esc_(value || '') + '</textarea>';
  return '<input data-array="PhotoItemsJson" data-index="' + i + '" data-key="' + escAttr_(key) + '" value="' + escAttr_(value || '') + '">';
}

function normalizeDocData_(tpl, project, data, record) {
  project = project || {};
  tpl = tpl || {};
  data = data || {};
  record = record || {};
  data.ProjectCode = data.ProjectCode || project.ProjectCode || getActiveProjectCode_() || 'ATL-LKL-001';
  data.ProjectName = data.ProjectName || data.ProjectNameSite || project.ProjectName || 'Lotus’s Klong Luang';
  data.ProjectNameSite = data.ProjectNameSite || data.ProjectName || project.ProjectName || 'Lotus’s Klong Luang';
  data.ClientName = data.ClientName || data.Client || project.Client || getSetting_('CLIENT_DEFAULT') || 'MKY';
  data.Client = data.Client || data.ClientName || project.Client || 'MKY';
  data.MainContractor = data.MainContractor || project.MainContractor || data.VendorInstaller || getSetting_('MAIN_CONTRACTOR_DEFAULT') || 'KYOUEI / SAAN';
  data.DocumentNo = data.DocumentNo || record.DocumentNo || 'Not issued – suffix XXX';
  data.RevisionNo = data.RevisionNo || record.RevisionNo || getSetting_('DEFAULT_REVISION') || '00';
  data.IssueNo = data.IssueNo || record.IssueNo || 'XXX';
  data.Date = dmsV3DateLong_(data.Date || data.InspectionDate || data.CompletionDate || todayLong_());
  if (tpl.TemplateCode === 'PJ-EQUIP-CHK-001') {
    data.TemplateCode = 'PJ-EQUIP-CHK-001';
    data.InspectionDate = data.InspectionDate || '2026-05-06';
    data.Date = dmsV3DateLong_(data.Date || data.InspectionDate);
    data.SystemName = data.SystemName || 'Niagara & AirPlug Equipment Installation';
    data.DrawingRef = data.DrawingRef || 'As-built drawings / installed location';
    data.ReferenceDocument = data.ReferenceDocument || '20260423 Equipment Checklist Lotus — Niagara & AirPlug';
    data.GeneralRemarks = data.GeneralRemarks || 'Real equipment checklist data imported from uploaded Excel file.';
    if (!data.AdvancedTableJson) data.AdvancedTableJson = JSON.stringify(DEFAULT_EQUIPMENT_ROWS);
  }
  if (tpl.TemplateCode === 'PJ-WCR-001' || /work completion/i.test(String(tpl.TemplateName || ''))) {
    data.TemplateCode = 'PJ-WCR-001';
    data.BranchLocation = data.BranchLocation || 'Lotus’s Klong Luang';
    data.PurchaseOrderNo = data.PurchaseOrderNo || 'Vol. no.075, No.3739 / 3741 / 3746 / 3743';
    data.ContractNo = data.ContractNo || '-';
    data.WorkType = data.WorkType || 'Equipment Purchasing / Installation / Implementation / BMS & BEMS Development';
    data.CompletionDate = data.CompletionDate || data.Date || '6 May 2026';
    data.ReferenceDocument = data.ReferenceDocument || 'Lotus Work Completion Report.xlsx — CoverPage / Photo Report / Gantt Chart';
    data.Remarks = data.Remarks || 'Work completion report data prepared from uploaded Lotus Work Completion Report workbook.';
    if (!data.WorkItemsJson) data.WorkItemsJson = JSON.stringify(DEFAULT_WCR_WORK_ITEMS);
    if (!data.PhotoItemsJson) data.PhotoItemsJson = JSON.stringify(DEFAULT_WCR_PHOTO_ITEMS);
  }
  return data;
}


