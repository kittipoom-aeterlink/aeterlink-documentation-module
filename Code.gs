function inlineField_(key, value, options, align) {
  if (options && options.editable) {
    return '<input data-field="' + escAttr_(key) + '" value="' + escAttr_(value || '') + '" style="text-align:' + (align || 'left') + '">';
  }
  return esc_(value || '');
}

function renderDocHeader_(title, tpl, project, data, options, pageNo, totalPages, continued) {
  project = project || {};
  tpl = tpl || {};
  data = data || {};
  options = options || {};
  var docNo = data.DocumentNo || (options.record && options.record.DocumentNo) || 'Not issued – suffix XXX';
  var rev = data.RevisionNo || (options.record && options.record.RevisionNo) || '00';
  var date = dmsV3DateLong_(data.Date || data.InspectionDate || data.CompletionDate || todayLong_());
  var subtitle = moduleSubtitle_(tpl) || 'Documentation Control';
  if (continued) subtitle += ' · Continued';
  return '' +
    '<div class="doc-head">' +
      '<div class="logo-box"><img src="' + DMS_V3_LOGO_URI + '" alt="AETERLINK"></div>' +
      '<div class="title-box"><h1>' + esc_(title) + '</h1><p>' + esc_(subtitle) + '</p></div>' +
      '<div class="meta-box">' +
        '<div class="meta-line"><b>Doc No.:</b><span class="meta-val">' + inlineField_('DocumentNo', docNo, options, 'left') + '</span></div>' +
        '<div class="meta-line"><b>Rev.:</b><span class="meta-val">' + inlineField_('RevisionNo', rev, options, 'left') + '</span></div>' +
        '<div class="meta-line"><b>Date:</b><span class="meta-val">' + inlineField_('Date', date, options, 'left') + '</span></div>' +
      '</div>' +
    '</div>' +
    '<div class="info-grid">' +
      infoCell_('Project Code', 'ProjectCode', data.ProjectCode || project.ProjectCode || '', options) +
      infoCell_('Project Name / Site', 'ProjectName', data.ProjectName || data.ProjectNameSite || project.ProjectName || '', options) +
      infoCell_('Client', 'ClientName', data.ClientName || data.Client || project.Client || '', options) +
      infoCell_('Main-Contractor', 'MainContractor', data.MainContractor || project.MainContractor || getSetting_('MAIN_CONTRACTOR_DEFAULT') || '', options) +
    '</div>';
}

function renderWcrInfoV3_(data, options) {
  return '<div class="section-title">DOCUMENT INFORMATION</div>' +
    '<table class="box-table wcr-info-table">' +
      '<tr><th>Contract No.</th><th>Purchase Order No.</th></tr>' +
      '<tr><td>' + fieldInput_('ContractNo', data.ContractNo || '-', options, 'text', 'left') + '</td><td>' + fieldInput_('PurchaseOrderNo', data.PurchaseOrderNo || 'Vol. no.075, No.3739 / 3741 / 3746 / 3743', options, 'text', 'left') + '</td></tr>' +
      '<tr><th>Work Type</th><th>Completion Date</th></tr>' +
      '<tr><td>' + fieldInput_('WorkType', data.WorkType || 'Equipment Purchasing / Installation / Implementation / BMS & BEMS Development', options, 'text', 'left') + '</td><td>' + fieldInput_('CompletionDate', data.CompletionDate || data.Date || '30 April 2026', options, 'text', 'left') + '</td></tr>' +
      '<tr><th colspan="2">Reference Documents</th></tr><tr class="ref-row"><td colspan="2">' + fieldInput_('ReferenceDocument', data.ReferenceDocument || '20260423 Equipment Checklist Lotus — Niagara & AirPlug', options, 'textarea', 'left') + '</td></tr>' +
      '<tr><th colspan="2">Remarks / Additional Notes</th></tr><tr class="remarks-row"><td colspan="2">' + fieldInput_('Remarks', data.Remarks || 'Work completion data and photo evidence imported from the uploaded Lotus Work Completion Report workbook.', options, 'textarea', 'left') + '</td></tr>' +
    '</table>';
}

function renderWorkCompletionReportDocumentV3_(tpl, project, data, options) {
  options = options || {};
  var work = parseArray_(data.WorkItemsJson || data.WorkItems, DEFAULT_WCR_WORK_ITEMS);
  var photos = parseArray_(data.PhotoItemsJson || data.PhotoItems, DEFAULT_WCR_PHOTO_ITEMS);
  if (!work.length) work = DEFAULT_WCR_WORK_ITEMS;
  if (!photos.length) photos = DEFAULT_WCR_PHOTO_ITEMS;

  // V11: conservative row counts so every page fits A4 exactly in browser print and Apps Script PDF.
  var firstRows = 12;
  var nextRows = 25;
  var photoPerPage = 2;
  var workPageCount = 1 + Math.max(0, Math.ceil(Math.max(0, work.length - firstRows) / nextRows));
  var photoPageCount = Math.max(1, Math.ceil(photos.length / photoPerPage));
  var totalPages = workPageCount + photoPageCount + 1;
  var html = '<div class="a4-root">' + dmsV3PageStyle_();
  var page = 1;

  html += '<div class="a4-page wcr-info-page">' +
    renderDocHeader_('WORK COMPLETION REPORT', tpl, project, data, options, page, totalPages, false) +
    renderWcrInfoV3_(data, options) +
    '<div class="section-title">SCOPE OF WORK — COMPLETION STATUS</div>' +
    renderWcrTableV3_(work, 0, firstRows, options) +
    renderFooter_(data, page, totalPages) +
    '</div>';
  page++;

  var cursor = firstRows;
  while (cursor < work.length) {
    html += '<div class="a4-page wcr-work-page">' +
      renderDocHeader_('WORK COMPLETION REPORT', tpl, project, data, options, page, totalPages, true) +
      '<div class="section-title">SCOPE OF WORK — CONTINUED</div>' +
      renderWcrTableV3_(work, cursor, nextRows, options) +
      renderFooter_(data, page, totalPages) +
      '</div>';
    cursor += nextRows;
    page++;
  }

  for (var ps = 0; ps < photos.length || (ps === 0 && photos.length === 0); ps += photoPerPage) {
    html += '<div class="a4-page photo-page wcr-photo-page">' +
      renderDocHeader_('WORK COMPLETION REPORT', tpl, project, data, options, page, totalPages, true) +
      '<div class="section-title">PHOTO REPORT</div>' +
      renderWcrPhotoGridV3_(photos, ps, photoPerPage, options) +
      renderFooter_(data, page, totalPages) +
      '</div>';
    page++;
  }

  html += '<div class="a4-page wcr-sign-page">' +
    renderDocHeader_('WORK COMPLETION REPORT', tpl, project, data, options, page, totalPages, true) +
    '<div class="section-title">COMPLETION CERTIFICATION</div>' +
    '<table class="box-table"><tr><td>This Work Completion Report is certified by the parties listed below. The completed works, supporting documents, and photo evidence have been reviewed as applicable.</td></tr></table>' +
    renderSignatureBlock_(options) +
    renderFooter_(data, page, totalPages) +
    '</div></div>';
  return html;
}


// ============================================================
// V12 PATCH — CLIENT SUBMITTAL NULL RESPONSE FIX
// No Google Sheet schema changes required.
// Fixes WebApp error: Cannot read properties of null (reading 'submittal')
// when pressing Submittal from DOCUMENT_REGISTER.
// ============================================================
try {
  if (typeof DMS !== 'undefined') {
    DMS.version = 'DOC_MODULE_STANDALONE_V12_SUBMITTAL_FIX_NO_SHEET_CHANGE';
    DMS.title = 'AETERLINK Documentation Control — V12 Submittal Fix';
  }
} catch(e) {}

function setupDocumentationModuleV12() {
  return apiDocumentModuleV12Health();
}

function setupDocumentationModuleV11() {
  return apiDocumentModuleV12Health();
}

function apiDocumentModuleV12Health() {
  var base = {};
  try { base = apiDocumentModuleV11Health ? apiDocumentModuleV11Health() : {}; } catch(e) { base = {ok:false, baseError:String(e && e.message || e)}; }
  base.ok = true;
  base.version = 'V12_SUBMITTAL_FIX';
  base.fix = 'apiCreateSubmittal now always returns a serializable object and validates empty/null responses.';
  try {
    base.documentRegisterRows = countRowsV12_('DOCUMENT_REGISTER');
    base.clientSubmittalRows = countRowsV12_('CLIENT_SUBMITTALS');
    base.recordLinkRows = countRowsV12_('RECORD_LINKS');
  } catch(e2) { base.countError = String(e2 && e2.message || e2); }
  return base;
}

function countRowsV12_(table) {
  try {
    var sh = ss_().getSheetByName(table);
    if (!sh) return 0;
    return Math.max(0, sh.getLastRow() - 1);
  } catch(e) { return 0; }
}

function plainV12_(obj) {
  obj = obj || {};
  var out = {};
  Object.keys(obj).forEach(function(k){
    var v = obj[k];
    if (v instanceof Date) out[k] = Utilities.formatDate(v, tz_ ? tz_() : 'Asia/Bangkok', 'yyyy-MM-dd HH:mm:ss');
    else if (v === undefined || v === null) out[k] = '';
    else out[k] = v;
  });
  return out;
}

function findDocumentRegisterV12_(documentId) {
  documentId = String(documentId || '').trim();
  if (!documentId) throw new Error('DocumentId is required for creating a client submittal.');
  var doc = findById_('DOCUMENT_REGISTER', documentId);
  if (doc) return doc;
  // Fallback search for cases where HTML entity / whitespace / display formatting is passed.
  var rows = readRows_('DOCUMENT_REGISTER', 'ALL', true, 5000) || [];
  for (var i = 0; i < rows.length; i++) {
    if (String(rows[i].DocumentId || '').trim() === documentId) return rows[i];
  }
  throw new Error('Document register record not found for DocumentId: ' + documentId);
}

function apiCreateClientSubmittal(documentId) {
  var lock = LockService.getScriptLock();
  var locked = false;
  try {
    locked = lock.tryLock(15000);
    var doc = findDocumentRegisterV12_(documentId);
    var sid = uid_('SUB');
    var submittedDate = (typeof today_ === 'function') ? today_() : Utilities.formatDate(new Date(), 'Asia/Bangkok', 'yyyy-MM-dd');

    var subPayload = {
      SubmittalId: sid,
      ProjectCode: doc.ProjectCode || '',
      DocumentCode: doc.DocumentCode || '',
      Title: doc.DocumentTitle || doc.Title || doc.DocumentCode || '',
      Revision: doc.Revision || doc.RevisionNo || '0',
      SubmittedDate: submittedDate,
      ClientStatus: 'Pending',
      ClientComment: '',
      ReturnedDate: '',
      FileUrl: doc.FileUrl || '',
      SubmissionNo: doc.SubmissionNo || '',
      TransmittalNo: doc.TransmittalNo || '',
      ReviewCycle: doc.ReviewCycle || '1',
      RequiredResponseDate: doc.RequiredResponseDate || '',
      NextAction: 'Submit to client / Awaiting response',
      SubmissionType: doc.DocumentType || doc.DocCategory || 'Document',
      GateStepId: doc.GateStepId || '',
      DocumentType: doc.DocumentType || '',
      DocumentCategory: doc.DocumentCategory || doc.DocCategory || '',
      Discipline: doc.Discipline || '',
      System: doc.System || '',
      Area: doc.Area || '',
      RequiredByPhase: doc.RequiredByPhase || '',
      RequiredStatus: doc.RequiredStatus || '',
      PlannedSubmitDate: submittedDate,
      ActualSubmitDate: submittedDate,
      Owner: doc.DocumentOwner || doc.GeneratedBy || '',
      RelatedDrawingNo: doc.DrawingNo || '',
      DocumentRegisterId: doc.DocumentId || documentId,
      StandardFlag: doc.StandardFlag || '',
      NativeFileUrl: doc.NativeFileUrl || '',
      SupportingDocUrl: doc.SupportingDocUrl || '',
      EvidenceFileUrl: doc.EvidenceFileUrl || '',
      RequiredForGate: doc.RequiredForGate || 'No'
    };

    var writtenSub = writeRow_('CLIENT_SUBMITTALS', subPayload, false) || subPayload;
    writtenSub.SubmittalId = writtenSub.SubmittalId || sid;

    doc.ClientStatus = 'Pending';
    doc.Status = doc.Status || 'Issued';
    var writtenDoc = writeRow_('DOCUMENT_REGISTER', doc, false) || doc;

    try {
      writeRow_('RECORD_LINKS', {
        LinkId: uid_('LNK'),
        ProjectCode: doc.ProjectCode || '',
        FromTable: 'DOCUMENT_REGISTER',
        FromRecordId: doc.DocumentId || documentId,
        ToTable: 'CLIENT_SUBMITTALS',
        ToRecordId: writtenSub.SubmittalId || sid,
        LinkType: 'CLIENT_SUBMITTAL',
        Description: 'Client submittal created from document register',
        FromId: doc.DocumentId || documentId,
        ToId: writtenSub.SubmittalId || sid,
        Remarks: 'Created by V12 submittal fix'
      }, true);
    } catch(linkErr) {
      // Do not fail the user action only because the optional link row failed.
    }

    try { audit_('CREATE_SUBMITTAL','CLIENT_SUBMITTALS',writtenSub.SubmittalId || sid,'Created from ' + (doc.DocumentId || documentId)); } catch(auditErr) {}

    return plainV12_(writtenSub);
  } catch(err) {
    throw new Error('Create submittal failed: ' + String(err && err.message || err));
  } finally {
    try { if (locked) lock.releaseLock(); } catch(e) {}
  }
}

function apiCreateSubmittal(documentId) {
  var sub = apiCreateClientSubmittal(documentId);
  if (!sub || !sub.SubmittalId) throw new Error('Submittal was not created. Empty response from server.');
  return {
    ok: true,
    submittal: plainV12_(sub),
    record: plainV12_(sub),
    message: 'Client submittal created successfully.',
    version: 'V12_SUBMITTAL_FIX'
  };
}


