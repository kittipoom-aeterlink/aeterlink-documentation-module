  if (!tpl) throw new Error('Template not found: ' + templateCode);
  var project = v7FindById_('PROJECTS', projectCode) || {ProjectCode:projectCode || 'ATL-LKL-001', ProjectName:'Lotus’s Klong Luang', Client:'MKY', MainContractor:'KYOUEI / SAAN'};
  var data = parseJson_(dataJson, {});
  options = options || {};
  return renderA4Html_(tpl, project, data, {
    editable: options.editable !== false,
    printMode: !!options.printMode,
    record: options.record || {}
  });
}

function v7FindById_(table, id) {
  if (!id) return null;
  var key = (v7Headers_(table)[0] || ((SCHEMA[table] || ['Id'])[0]));
  var rows = v7ReadRows_(table, {includeDeleted:true, maxRows:3000});
  for (var i=0; i<rows.length; i++) {
    if (String(rows[i][key] || '').trim() === String(id).trim()) return rows[i];
  }
  return null;
}

