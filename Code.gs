function dmsCellFlex_(content, align) {
  var cls = align === 'left' ? 'cell-flex left' : 'cell-flex';
  return '<div class="' + cls + '">' + content + '</div>';
}

function dmsCellText_(value, align) {
  return dmsCellFlex_('<span class="cell-text">' + esc_(value || '') + '</span>', align);
}

function wcrCell_(i, key, value, options, align) {
  var cls = align === 'left' ? 'left' : '';
  if (!options.editable) return '<td class="' + cls + '">' + dmsCellText_(value || '', align) + '</td>';
  var wrapKeys = {WorkDescription:true, Remarks:true, Package:true};
  var taStyle = 'text-align:' + (align || 'center');
  if (wrapKeys[key]) {
    return '<td class="' + cls + '">' + dmsCellFlex_('<textarea data-array="WorkItemsJson" data-index="' + i + '" data-key="' + escAttr_(key) + '" style="' + taStyle + '">' + esc_(value || '') + '</textarea>', align) + '</td>';
  }
  return '<td class="' + cls + '">' + dmsCellFlex_('<input data-array="WorkItemsJson" data-index="' + i + '" data-key="' + escAttr_(key) + '" value="' + escAttr_(value || '') + '" style="' + taStyle + '">', align) + '</td>';
}

function eqCell_(i, key, value, options, align) {
  var cls = align === 'left' ? 'left' : '';
  if (!options.editable) return '<td class="' + cls + '">' + dmsCellText_(value || '', align) + '</td>';
  var wrapKeys = {ItemDescription:true, ProductName:true, Localisation:true, InstallationPosition:true, InstallationCondition:true, PowerOnConfirmation:true, Remarks:true};
  var taStyle = 'text-align:' + (align || 'center');
  if (wrapKeys[key]) {
    return '<td class="' + cls + '">' + dmsCellFlex_('<textarea data-array="AdvancedTableJson" data-index="' + i + '" data-key="' + escAttr_(key) + '" style="' + taStyle + '">' + esc_(value || '') + '</textarea>', align) + '</td>';
  }
  return '<td class="' + cls + '">' + dmsCellFlex_('<input data-array="AdvancedTableJson" data-index="' + i + '" data-key="' + escAttr_(key) + '" value="' + escAttr_(value || '') + '" style="' + taStyle + '">', align) + '</td>';
}


