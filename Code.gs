function renderEquipmentChecklistDocumentV3_(tpl, project, data, options) {
  var rows = parseEqTableRowsV3_(data.AdvancedTableJson);
  if (!rows.length) rows = DEFAULT_EQUIPMENT_ROWS;
  rows = rows.map(function(r, i) { r.No = r.No || String(i + 1); return r; });
  // V14: fewer rows per page because margins and fonts are larger.
  var firstRows = 14, nextRows = 18;
  var tablePages = [];
  tablePages.push({start:0, count:firstRows, first:true});
  var cursor = firstRows;
  while (cursor < rows.length) { tablePages.push({start:cursor, count:nextRows, first:false}); cursor += nextRows; }
  var totalPages = tablePages.length + 1;
  var html = '<div class="a4-root">' + dmsV3PageStyle_();
  for (var p = 0; p < tablePages.length; p++) {
    var pg = tablePages[p];
    html += '<div class="a4-page">' + renderDocHeader_('EQUIPMENT CHECKLIST', tpl, project, data, options, p + 1, totalPages, !pg.first);
    if (pg.first) {
      html += '<div class="section-title">DOCUMENT INFORMATION</div>' +
        '<table class="box-table"><tr><th>Drawing References</th></tr><tr><td>' + fieldInput_('DrawingRef', data.DrawingRef || 'As-built drawings / installed location', options, 'textarea', 'left') + '</td></tr>' +
        '<tr><th>Reference Documents</th></tr><tr><td>' + fieldInput_('ReferenceDocument', data.ReferenceDocument || '20260423 Equipment Checklist Lotus — Niagara & AirPlug', options, 'textarea', 'left') + '</td></tr></table>' +
        '<div class="section-title">EQUIPMENT CHECKLIST</div>';
    } else {
      html += '<div class="section-title">EQUIPMENT CHECKLIST — CONTINUED</div>';
    }
    html += renderEqTableV3_(rows, pg.start, pg.count, options) + renderFooter_(data, p + 1, totalPages) + '</div>';
  }
  html += '<div class="a4-page">' + renderDocHeader_('EQUIPMENT CHECKLIST', tpl, project, data, options, totalPages, totalPages, true) + renderEqSummaryV3_(data, rows, options) + renderSignatureBlock_(options) + renderFooter_(data, totalPages, totalPages) + '</div></div>';
  return html;
}

function renderEqTableV3_(rows, start, count, options) {
  var part = rows.slice(start, start + count);
  var html = '<table class="a4-table eq-table"><thead><tr>' +
    '<th style="width:4.5%">No.</th><th style="width:18%">Item description</th><th style="width:8.5%">Brand</th><th style="width:12%">Product name</th><th style="width:7%">Installed<br>Qty</th><th style="width:10.5%">Localisation</th><th style="width:5.5%">Floor</th><th style="width:10%">Position<br>(As-built)</th><th style="width:9.5%">Condition<br>(no risk)</th><th style="width:9.5%">Power-on<br>Confirm</th><th style="width:8.5%">Remarks</th>' +
    (options.editable ? '<th class="print-hidden" style="width:7%">Action</th>' : '') + '</tr></thead><tbody>';
  part.forEach(function(r, j) {
    var i = start + j;
    html += '<tr data-array-row="AdvancedTableJson" data-index="' + i + '">' +
      '<td>' + (i + 1) + '</td>' +
      eqCell_(i, 'ItemDescription', r.ItemDescription, options, 'center') +
      eqCell_(i, 'Brand', r.Brand, options, 'center') +
      eqCell_(i, 'ProductName', r.ProductName, options, 'center') +
      eqCell_(i, 'InstalledQuantity', r.InstalledQuantity, options, 'center') +
      eqCell_(i, 'Localisation', r.Localisation, options, 'center') +
      eqCell_(i, 'Floor', r.Floor, options, 'center') +
      eqCell_(i, 'InstallationPosition', r.InstallationPosition, options, 'center') +
      eqCell_(i, 'InstallationCondition', r.InstallationCondition, options, 'center') +
      eqCell_(i, 'PowerOnConfirmation', r.PowerOnConfirmation, options, 'center') +
      eqCell_(i, 'Remarks', r.Remarks, options, 'center') +
      (options.editable ? '<td class="row-actions print-hidden"><button onclick="a4AddRow(&quot;AdvancedTableJson&quot;,' + i + ')">＋</button><button onclick="a4DeleteRow(&quot;AdvancedTableJson&quot;,' + i + ')">−</button><button onclick="a4MoveRow(&quot;AdvancedTableJson&quot;,' + i + ',-1)">↑</button><button onclick="a4MoveRow(&quot;AdvancedTableJson&quot;,' + i + ',1)">↓</button></td>' : '') +
    '</tr>';
  });
  return html + '</tbody></table>';
}

function eqCell_(i, key, value, options, align) {
  var cls = align === 'left' ? 'left' : '';
  if (!options.editable) return '<td class="' + cls + '">' + esc_(value || '') + '</td>';
  var wrapKeys = {ItemDescription:true, ProductName:true, Localisation:true, InstallationPosition:true, InstallationCondition:true, PowerOnConfirmation:true, Remarks:true};
  if (wrapKeys[key]) {
    return '<td class="' + cls + '"><textarea data-array="AdvancedTableJson" data-index="' + i + '" data-key="' + escAttr_(key) + '" style="text-align:' + (align || 'center') + '">' + esc_(value || '') + '</textarea></td>';
  }
  return '<td class="' + cls + '"><input data-array="AdvancedTableJson" data-index="' + i + '" data-key="' + escAttr_(key) + '" value="' + escAttr_(value || '') + '" style="text-align:' + (align || 'center') + '"></td>';
}

function renderWorkCompletionReportDocumentV3_(tpl, project, data, options) {
  var work = parseArray_(data.WorkItemsJson || data.WorkItems, DEFAULT_WCR_WORK_ITEMS);
  var photos = parseArray_(data.PhotoItemsJson || data.PhotoItems, DEFAULT_WCR_PHOTO_ITEMS);
  if (!work.length) work = DEFAULT_WCR_WORK_ITEMS;
  if (!photos.length) photos = DEFAULT_WCR_PHOTO_ITEMS;
  // V14: fewer rows per page to allow larger fonts and wrapped text.
  var firstRows = 13, nextRows = 21, photoPerPage = 2;
  var workPageCount = 1 + Math.max(0, Math.ceil(Math.max(0, work.length - firstRows) / nextRows));
  var photoPageCount = Math.max(1, Math.ceil(photos.length / photoPerPage));
  var totalPages = workPageCount + photoPageCount + 1;
  var html = '<div class="a4-root">' + dmsV3PageStyle_();
  var page = 1;
  html += '<div class="a4-page">' + renderDocHeader_('WORK COMPLETION REPORT', tpl, project, data, options, page, totalPages, false) + renderWcrInfoV3_(data, options) + '<div class="section-title">SCOPE OF WORK — COMPLETION STATUS</div>' + renderWcrTableV3_(work, 0, firstRows, options) + renderFooter_(data, page, totalPages) + '</div>';
  page++;
  var cursor = firstRows;
  while (cursor < work.length) {
    html += '<div class="a4-page">' + renderDocHeader_('WORK COMPLETION REPORT', tpl, project, data, options, page, totalPages, true) + '<div class="section-title">SCOPE OF WORK — CONTINUED</div>' + renderWcrTableV3_(work, cursor, nextRows, options) + renderFooter_(data, page, totalPages) + '</div>';
    cursor += nextRows; page++;
  }
  for (var ps = 0; ps < photos.length || (ps === 0 && photos.length === 0); ps += photoPerPage) {
    html += '<div class="a4-page photo-page">' + renderDocHeader_('WORK COMPLETION REPORT', tpl, project, data, options, page, totalPages, true) + '<div class="section-title">PHOTO REPORT</div>' + renderWcrPhotoGridV3_(photos, ps, photoPerPage, options) + renderFooter_(data, page, totalPages) + '</div>';
    page++;
  }
  html += '<div class="a4-page">' + renderDocHeader_('WORK COMPLETION REPORT', tpl, project, data, options, page, totalPages, true) + '<div class="section-title">COMPLETION CERTIFICATION</div><table class="box-table"><tr><td>This Work Completion Report is certified by the parties listed below. The completed works, supporting documents, and photo evidence have been reviewed as applicable.</td></tr></table>' + renderSignatureBlock_(options) + renderFooter_(data, page, totalPages) + '</div></div>';
  return html;
}

function renderWcrInfoV3_(data, options) {
  return '<div class="section-title">DOCUMENT INFORMATION</div>' +
    '<table class="box-table wcr-info-table">' +
      '<tr><th>Contract No.</th><th>Purchase Order No.</th></tr>' +
      '<tr><td>' + fieldInput_('ContractNo', data.ContractNo || '-', options, 'text', 'left') + '</td><td>' + fieldInput_('PurchaseOrderNo', data.PurchaseOrderNo || 'Vol. no.075, No.3739 / 3741 / 3746 / 3743', options, 'text', 'left') + '</td></tr>' +
      '<tr><th>Work Type</th><th>Completion Date</th></tr>' +
      '<tr><td>' + fieldInput_('WorkType', data.WorkType || 'Equipment Purchasing / Installation / Implementation / BMS & BEMS Development', options, 'text', 'left') + '</td><td>' + fieldInput_('CompletionDate', data.CompletionDate || data.Date || '30 April 2026', options, 'text', 'left') + '</td></tr>' +
      '<tr><th colspan="2">Reference Documents</th></tr><tr class="ref-row"><td colspan="2">' + fieldInput_('ReferenceDocument', data.ReferenceDocument || '20260423 Equipment Checklist Lotus — Niagara & AirPlug', options, 'textarea', 'left') + '</td></tr>' +
      '<tr><th colspan="2">Remarks / Additional Notes</th></tr><tr class="remarks-row"><td colspan="2">' + fieldInput_('Remarks', data.Remarks || 'Work completion data and photo evidence imported from the uploaded Lotus Work Completion Report workbook.', options, 'textarea', 'left') + '</td></tr>' +
    '</table>';
}

function renderWcrTableV3_(work, start, count, options) {
  var part = work.slice(start, start + count);
  var html = '<table class="a4-table wcr-table"><thead><tr><th style="width:12%">Package</th><th style="width:8%">Item</th><th>Work Description</th><th style="width:8%">Qty.</th><th style="width:8%">Unit</th><th style="width:11%">Status</th><th style="width:12%">Remarks</th>' + (options.editable ? '<th class="print-hidden" style="width:9%">Action</th>' : '') + '</tr></thead><tbody>';
  part.forEach(function(r, j) {
    var i = start + j;
    html += '<tr data-array-row="WorkItemsJson" data-index="' + i + '">' +
      wcrCell_(i, 'Package', r.Package, options, 'center') +
      wcrCell_(i, 'Item', r.Item, options, 'center') +
      wcrCell_(i, 'WorkDescription', r.WorkDescription, options, 'center') +
      wcrCell_(i, 'Qty', r.Qty, options, 'center') +
      wcrCell_(i, 'Unit', r.Unit, options, 'center') +
      wcrCell_(i, 'Status', r.Status, options, 'center') +
      wcrCell_(i, 'Remarks', r.Remarks, options, 'center') +
      (options.editable ? '<td class="row-actions print-hidden"><button onclick="a4AddRow(&quot;WorkItemsJson&quot;,' + i + ')">＋</button><button onclick="a4DeleteRow(&quot;WorkItemsJson&quot;,' + i + ')">−</button><button onclick="a4MoveRow(&quot;WorkItemsJson&quot;,' + i + ',-1)">↑</button><button onclick="a4MoveRow(&quot;WorkItemsJson&quot;,' + i + ',1)">↓</button></td>' : '') +
    '</tr>';
  });
  return html + '</tbody></table>';
}

function wcrCell_(i, key, value, options, align) {
  var cls = align === 'left' ? 'left' : '';
  if (!options.editable) return '<td class="' + cls + '">' + esc_(value || '') + '</td>';
  var wrapKeys = {WorkDescription:true, Remarks:true, Package:true};
  if (wrapKeys[key]) {
    return '<td class="' + cls + '"><textarea data-array="WorkItemsJson" data-index="' + i + '" data-key="' + escAttr_(key) + '" style="text-align:' + (align || 'center') + '">' + esc_(value || '') + '</textarea></td>';
  }
  return '<td class="' + cls + '"><input data-array="WorkItemsJson" data-index="' + i + '" data-key="' + escAttr_(key) + '" value="' + escAttr_(value || '') + '" style="text-align:' + (align || 'center') + '"></td>';
}

function renderWcrPhotoGridV3_(photos, start, count, options) {
  var part = photos.slice(start, start + count);
  while (part.length < count) part.push({ItemNo:'', Description:'', Note:'', ImageKey:'', ImageData:''});
  var html = '<div class="photo-list">';
  part.forEach(function(p, j) {
    var i = start + j;
    var src = p.ImageData || (p.ImageKey && DMS_V3_WCR_IMAGE_MAP[p.ImageKey]) || '';
    html += '<div class="photo-row" data-array-row="PhotoItemsJson" data-index="' + i + '">' +
      (options.editable ? '<input type="hidden" data-array="PhotoItemsJson" data-index="' + i + '" data-key="ImageKey" value="' + escAttr_(p.ImageKey || '') + '"><input type="hidden" data-array="PhotoItemsJson" data-index="' + i + '" data-key="ImageData" value="' + escAttr_(p.ImageData || '') + '">' : '') +
      '<div class="photo-left">' + (src ? '<img src="' + escAttr_(src) + '">' : '<div class="photo-placeholder">PHOTO AREA<br>Insert / replace image</div>') + '</div>' +
      '<div class="photo-right">' +
        '<div class="photo-label">Item No.</div><div class="photo-input-box">' + photoFieldV6_(i, 'ItemNo', p.ItemNo, options, 'text') + '</div>' +
        '<div class="photo-label">Description</div><div class="photo-text">' + photoFieldV6_(i, 'Description', p.Description, options, 'textarea') + '</div>' +
        '<div class="photo-label">Note</div><div class="photo-ruled">' + photoFieldV6_(i, 'Note', p.Note, options, 'textarea') + '</div>' +
        (options.editable ? '<div class="photo-actions print-hidden"><button onclick="a4PickPhoto(' + i + ')">Add / Replace</button><button onclick="a4ClearPhoto(' + i + ')">Clear</button><button class="blue" onclick="a4AddRow(&quot;PhotoItemsJson&quot;,' + i + ')">+</button><button class="red" onclick="a4DeleteRow(&quot;PhotoItemsJson&quot;,' + i + ')">−</button><button onclick="a4MoveRow(&quot;PhotoItemsJson&quot;,' + i + ',-1)">↑</button><button onclick="a4MoveRow(&quot;PhotoItemsJson&quot;,' + i + ',1)">↓</button></div>' : '') +
      '</div>' +
    '</div>';
  });
  return html + '</div>';
}


