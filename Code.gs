function createPdfForRecord_(record) {
  var tpl = findById_('FORM_TEMPLATES', record.TemplateCode);
  if (!tpl) throw new Error('Template not found: ' + record.TemplateCode);
  var project = getProject_(record.ProjectCode);
  var data = parseJson_(record.DataJson, {});
  var html = renderA4Html_(tpl, project, data, {editable:false, printMode:true, record:record});
  var name = (record.DocumentNo || record.FormRecordId || uid_('DOC')) + '.pdf';
  var blob = Utilities.newBlob(html, 'text/html', name.replace(/\.pdf$/,'') + '.html').getAs('application/pdf').setName(name);
  var folderId = getSetting_('PDF_FOLDER_ID');
  var file = folderId ? DriveApp.getFolderById(folderId).createFile(blob) : DriveApp.createFile(blob);
  return {id:file.getId(), url:file.getUrl(), name:file.getName()};
}

