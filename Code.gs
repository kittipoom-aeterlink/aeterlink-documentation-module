// Helpers
// ─────────────────────────────────────────────
function setupIfEmpty_() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  if (!ss.getSheetByName('FORM_TEMPLATES')) setupDocumentationModuleV4();
}

function headers_(table) {
  var sh = SpreadsheetApp.getActiveSpreadsheet().getSheetByName(table);
  if (!sh || sh.getLastRow() < 1) return (SCHEMA[table] || []).slice();
  var h = sh.getRange(1,1,1,Math.max(1, sh.getLastColumn())).getDisplayValues()[0].map(function(x){ return String(x||'').trim(); }).filter(Boolean);
  return h.length ? h : (SCHEMA[table] || []).slice();
}

function idField_(table) {
  return (headers_(table)[0] || (SCHEMA[table] || ['Id'])[0]);
}

function assertTable_(table) {
  if (!SCHEMA[table]) throw new Error('Unknown table: ' + table);
}

function readRows_(table, options) {
  options = options || {};
  var sh = SpreadsheetApp.getActiveSpreadsheet().getSheetByName(table);
  if (!sh) return [];
  var values = sh.getDataRange().getDisplayValues();
  if (!values || values.length < 2) return [];
  var h = values[0].map(function(x){ return String(x || '').trim(); });
  var idxDel = h.indexOf('IsDeleted');
  var idxProject = h.indexOf('ProjectCode');
  var projectCode = String(options.projectCode || '').trim();
  var max = Number(options.maxRows || 2000);
  var out = [];
  for (var r = 1; r < values.length; r++) {
    if (out.length >= max) break;
    var row = values[r];
    var blank = row.every(function(v){ return String(v || '').trim() === ''; });
    if (blank) continue;
    if (!options.includeDeleted && idxDel >= 0 && String(row[idxDel]).toUpperCase() === 'TRUE') continue;
    if (projectCode && idxProject >= 0 && String(row[idxProject]).trim() !== projectCode) continue;
    var o = {_row:r+1};
    h.forEach(function(k, i){ if (k) o[k] = row[i]; });
    out.push(o);
  }
  return out;
}

function findById_(table, id) {
  var key = idField_(table);
  var rows = readRows_(table, {includeDeleted:true, maxRows:5000});
  for (var i=0; i<rows.length; i++) {
    if (String(rows[i][key]).trim() === String(id).trim()) return rows[i];
  }
  return null;
}

function writeRow_(table, obj, seedMode) {
  assertTable_(table);
  obj = obj || {};
  var sh = ensureSheet_(table);
  var h = headers_(table);
  var key = h[0] || 'Id';
  if (!obj[key]) obj[key] = uid_(String(key).replace(/Id|Code/g,'').toUpperCase());
  var id = String(obj[key]).trim();
  var rowNo = 0;
  if (sh.getLastRow() >= 2) {
    var ids = sh.getRange(2,1,sh.getLastRow()-1,1).getDisplayValues();
    for (var i=0; i<ids.length; i++) {
      if (String(ids[i][0]).trim() === id) { rowNo = i+2; break; }
    }
  }
  var rec = {};
  if (rowNo) {
    var old = sh.getRange(rowNo,1,1,h.length).getDisplayValues()[0];
    h.forEach(function(k, i){ rec[k] = old[i]; });
  }
  Object.keys(obj).forEach(function(k){ rec[k] = obj[k]; });
  var now = now_();
  if (h.indexOf('UpdatedAt') >= 0) rec.UpdatedAt = rec.UpdatedAt || now;
  if (h.indexOf('UpdatedBy') >= 0) rec.UpdatedBy = rec.UpdatedBy || email_();
  if (!rowNo) {
    if (h.indexOf('CreatedAt') >= 0 && !rec.CreatedAt) rec.CreatedAt = now;
    if (h.indexOf('Revision') >= 0 && !rec.Revision) rec.Revision = 1;
    if (h.indexOf('IsDeleted') >= 0 && rec.IsDeleted === undefined) rec.IsDeleted = false;
  } else if (!seedMode && h.indexOf('Revision') >= 0) {
    rec.Revision = Number(rec.Revision || 0) + 1;
  }
  var row = h.map(function(k){ return rec[k] === undefined ? '' : rec[k]; });
  if (rowNo) sh.getRange(rowNo,1,1,h.length).setValues([row]);
  else sh.appendRow(row);
  return rec;
}

function audit_(action, table, id, beforeJson, afterJson) {
  try {
    writeRow_('AUDIT_LOG', {
      AuditId:uid_('AUD'),
      DateTime:now_(),
      UserEmail:email_(),
      Action:action,
      TableName:table,
      RecordId:id,
      BeforeJson:beforeJson || '',
      AfterJson:afterJson || '',
      Message:''
    }, true);
  } catch(e) {}
}

function getProject_(projectCode) {
  projectCode = projectCode || getActiveProjectCode_();
  var p = findById_('PROJECTS', projectCode);
  if (p) return p;
  var rows = readRows_('PROJECTS', {maxRows:1});
  return rows[0] || {ProjectCode:projectCode || 'ATL-LKL-001', ProjectName:'Lotus’s Klong Luang', Client:'MKY', MainContractor:'KYOUEI / SAAN'};
}

function getActiveProjectCode_() {
  return getSetting_('ACTIVE_PROJECT_CODE') || 'ATL-LKL-001';
}

function getSetting_(key) {
  var rows = readRows_('SETTINGS', {maxRows:500, includeDeleted:true});
  for (var i=0; i<rows.length; i++) {
    if (String(rows[i].Key || '') === String(key)) return rows[i].Value || '';
  }
  return '';
}

function setSetting_(key, value, description) {
  return writeRow_('SETTINGS', {Key:key, Value:value, Description:description || ''}, false);
}

function groupLists_() {
  var out = {};
  readRows_('LISTS', {maxRows:2000}).forEach(function(r) {
    var name = String(r.ListName || '').split('|')[0];
    if (!out[name]) out[name] = [];
    out[name].push(r.Value);
  });
  return out;
}

function nextIssueNo_(projectCode, templateCode) {
  var rows = readRows_('FORM_RECORDS', {projectCode:projectCode, includeDeleted:false, maxRows:5000})
    .filter(function(r){ return r.TemplateCode === templateCode && /^\d+$/.test(String(r.IssueNo || '')); });
  var max = 0;
  rows.forEach(function(r){ max = Math.max(max, parseInt(r.IssueNo,10) || 0); });
  return String(max + 1).padStart(3, '0');
}

function docCodeForTemplate_(tpl) {
  if (tpl.TemplateCode === 'PJ-EQUIP-CHK-001') return getSetting_('DOCUMENT_CODE_EQC') || 'PJ-EQC-001';
  if (tpl.TemplateCode === 'PJ-WCR-001') return getSetting_('DOCUMENT_CODE_WCR') || 'PJ-WCR-001';
  return tpl.TemplateCode;
}

function docCategoryFromPhase_(phaseNo) {
  var n = parseInt(phaseNo, 10);
  if (n <= 2) return 'Pre-construction';
  if (n <= 6) return 'Construction';
  return 'Post-construction';
}

function moduleSubtitle_(tpl) {
  var a = [];
  if (tpl.Module) a.push(tpl.Module);
  if (tpl.DocCategory) a.push(tpl.DocCategory);
  return a.join(' · ');
}

function parseFields_(json) {
  var arr = parseJson_(json, []);
  return Array.isArray(arr) ? arr : [];
}

function parseJson_(s, fallback) {
  if (s === null || s === undefined || s === '') return fallback;
  if (typeof s === 'object') return s;
  try { return JSON.parse(String(s)); } catch(e) { return fallback; }
}

function parseArray_(s, fallback) {
  var arr = parseJson_(s, fallback || []);
  return Array.isArray(arr) ? arr : (fallback || []);
}

function unique_(arr) {
  var m = {}, out = [];
  (arr || []).forEach(function(x){ x = String(x || '').trim(); if (x && !m[x]) { m[x]=true; out.push(x); } });
  return out;
}

function now_() { return new Date(); }
function today_() { return Utilities.formatDate(new Date(), DMS.tz, 'yyyy-MM-dd'); }
function todayLong_() { return Utilities.formatDate(new Date(), DMS.tz, 'd MMM yyyy'); }
function email_() { try { return (Session.getActiveUser().getEmail() || Session.getEffectiveUser().getEmail() || 'unknown@local').toLowerCase(); } catch(e) { return 'unknown@local'; } }
function uid_(prefix) { return String(prefix || 'REC') + '-' + Utilities.formatDate(new Date(), DMS.tz, 'yyyyMMddHHmmss') + '-' + Math.random().toString(36).slice(2,7).toUpperCase(); }
function esc_(s) { return String(s == null ? '' : s).replace(/[&<>"']/g, function(m){ return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]; }); }
function escAttr_(s) { return esc_(s).replace(/\n/g, '&#10;'); }


