// ─────────────────────────────────────────────
// Setup / seed
// ─────────────────────────────────────────────
function setupDocumentationModule() {
  return setupDocumentationModuleV4();
}

function setupDocumentationModuleV2() {
  // Backward compatible entry point. V2 setup was slow because it used appendRow/findById repeatedly.
  return setupDocumentationModuleV4();
}

function setupDocumentationModuleV3() {
  // Backward compatible entry point for the version shown in your screenshot.
  return setupDocumentationModuleV4();
}

function setupDocumentationModuleV4() {
  var started = new Date();
  Logger.log('AETERLINK Documentation Module V4 fast setup started');
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  if (!ss) throw new Error('No active spreadsheet. Open Apps Script from the target Google Sheet.');

  Object.keys(SCHEMA).forEach(function(t){ ensureSheetFastV4_(ss, t); });

  // Fast seed: batch-write large master tables instead of appendRow/findById loops.
  seedSettingsFastV4_();
  seedListsFastV4_();
  seedCurrentUserFastV4_();
  seedDemoProjectFastV4_();
  seedFormTemplatesFastV4_();
  seedDocumentRulesFastV4_();

  // Keep the full old-code layouts/data for Work Completion Report + Equipment Checklist.
  dmsV3UpsertSpecialTemplates_();

  formatCoreSheetsV4_();
  SpreadsheetApp.flush();
  Logger.log('AETERLINK Documentation Module V4 fast setup finished in ' + (new Date().getTime() - started.getTime()) + ' ms');
  var r = apiHealthCheck();
  r.ok = true;
  r.version = DMS.version;
  r.setupVersion = 'V4_FAST_SETUP';
  r.setupMs = new Date().getTime() - started.getTime();
  r.patch = DMS_V3_PATCH || 'WCR/EQC old-code layout and data retained';
  return r;
}

function ensureSheetFastV4_(ss, table) {
  var wanted = SCHEMA[table] || [];
  if (!wanted.length) throw new Error('Unknown table: ' + table);
  var sh = ss.getSheetByName(table);
  if (!sh) sh = ss.insertSheet(table);

  var current = [];
  if (sh.getLastRow() >= 1 && sh.getLastColumn() >= 1) {
    current = sh.getRange(1,1,1,sh.getLastColumn()).getDisplayValues()[0]
      .map(function(x){ return String(x || '').trim(); });
  }
  var nonBlank = current.filter(Boolean);
  if (!nonBlank.length) {
    sh.getRange(1,1,1,wanted.length).setValues([wanted]);
  } else {
    var add = wanted.filter(function(h){ return nonBlank.indexOf(h) < 0; });
    if (add.length) sh.getRange(1, nonBlank.length + 1, 1, add.length).setValues([add]);
  }

  try {
    sh.setFrozenRows(1);
    sh.getRange(1,1,1,Math.max(wanted.length, sh.getLastColumn()))
      .setBackground('#244963')
      .setFontColor('#FFFFFF')
      .setFontWeight('bold')
      .setHorizontalAlignment('center')
      .setVerticalAlignment('middle')
      .setWrap(true);
  } catch(e) {}
  return sh;
}

function resetSeedTableFastV4_(table, rows) {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sh = ensureSheetFastV4_(ss, table);
  var h = headers_(table);
  var maxRows = Math.max(sh.getMaxRows() - 1, 1);
  var maxCols = Math.max(sh.getLastColumn(), h.length, 1);
  if (sh.getMaxRows() > 1) sh.getRange(2,1,maxRows,maxCols).clearContent();
  if (!rows || !rows.length) return 0;
  var matrix = buildRowsMatrixFastV4_(h, rows);
  if (sh.getMaxRows() < rows.length + 1) sh.insertRowsAfter(sh.getMaxRows(), rows.length + 1 - sh.getMaxRows());
  sh.getRange(2,1,matrix.length,h.length).setValues(matrix);
  return rows.length;
}

function upsertRowsFastV4_(table, rows) {
  if (!rows || !rows.length) return 0;
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sh = ensureSheetFastV4_(ss, table);
  var h = headers_(table);
  var key = h[0];
  var keyIndex = 0;
  var existingMap = {};
  if (sh.getLastRow() >= 2) {
    var ids = sh.getRange(2, keyIndex + 1, sh.getLastRow() - 1, 1).getDisplayValues();
    ids.forEach(function(r, i){ if (String(r[0] || '').trim()) existingMap[String(r[0]).trim()] = i + 2; });
  }
  var appendRows = [];
  rows.forEach(function(rowObj){
    var id = String(rowObj[key] || '').trim();
    if (!id) return;
    var matrixRow = buildRowsMatrixFastV4_(h, [rowObj])[0];
    if (existingMap[id]) sh.getRange(existingMap[id],1,1,h.length).setValues([matrixRow]);
    else appendRows.push(matrixRow);
  });
  if (appendRows.length) {
    if (sh.getMaxRows() < sh.getLastRow() + appendRows.length) sh.insertRowsAfter(sh.getMaxRows(), sh.getLastRow() + appendRows.length - sh.getMaxRows());
    sh.getRange(sh.getLastRow()+1,1,appendRows.length,h.length).setValues(appendRows);
  }
  return rows.length;
}

function buildRowsMatrixFastV4_(headers, rows) {
  var now = now_();
  var user = email_();
  return rows.map(function(src){
    var rec = {};
    Object.keys(src || {}).forEach(function(k){ rec[k] = src[k]; });
    if (headers.indexOf('CreatedAt') >= 0 && !rec.CreatedAt) rec.CreatedAt = now;
    if (headers.indexOf('UpdatedAt') >= 0) rec.UpdatedAt = now;
    if (headers.indexOf('UpdatedBy') >= 0) rec.UpdatedBy = rec.UpdatedBy || user;
    if (headers.indexOf('Revision') >= 0 && !rec.Revision) rec.Revision = 1;
    if (headers.indexOf('RevisionNo') >= 0 && !rec.RevisionNo) rec.RevisionNo = '00';
    if (headers.indexOf('IsDeleted') >= 0 && rec.IsDeleted === undefined) rec.IsDeleted = false;
    return headers.map(function(k){ return rec[k] === undefined ? '' : rec[k]; });
  });
}

