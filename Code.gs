function apiGetRecord(table, id) {
  assertTable_(table);
  var rec = findById_(table, id);
  if (!rec) throw new Error('Record not found: ' + table + ' / ' + id);
  return {ok:true, table:table, id:id, record:rec};
}

function apiCreateFormRecordFromTemplate(templateCode, projectCode, dataObjOrJson) {
  var data = {};
  if (typeof dataObjOrJson === 'string') data = parseJson_(dataObjOrJson, {});
  else data = dataObjOrJson || {};
  var rec = apiSaveDraft(templateCode, projectCode, JSON.stringify(data), '');
  return {ok:true, formRecord:rec, record:rec};
}

function apiGeneratePdfFromFormRecord(formRecordId) {
  var pdf = apiGeneratePdfForRecord(formRecordId);
  return {ok:true, url:(pdf && pdf.url) || '', fileId:(pdf && pdf.fileId) || '', pdf:pdf};
}

function apiPreviewHtmlFromFormRecord(formRecordId) {
  var rec = findById_('FORM_RECORDS', formRecordId);
  if (!rec) throw new Error('Record not found: ' + formRecordId);
  var html = apiPreviewHtml(rec.TemplateCode, rec.ProjectCode, rec.DataJson || '{}', {editable:false, printMode:false, record:rec});
  return {ok:true, html:html, record:rec};
}

function apiCreateSubmittal(documentId) {
  var sub = apiCreateClientSubmittal(documentId);
  return {ok:true, submittal:sub, record:sub};
}

function apiOpenA4Record(formRecordId, editable) {
  var rec = findById_('FORM_RECORDS', formRecordId);
  if (!rec) throw new Error('Record not found: ' + formRecordId);
  var tpl = findById_('FORM_TEMPLATES', rec.TemplateCode);
  if (!tpl) throw new Error('Template not found: ' + rec.TemplateCode);
  var html = apiPreviewHtml(rec.TemplateCode, rec.ProjectCode, rec.DataJson || '{}', {editable:editable !== false, printMode:false, record:rec});
  return {ok:true, record:rec, template:tpl, html:html};
}

