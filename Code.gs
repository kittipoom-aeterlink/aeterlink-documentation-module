function renderA4Html_(tpl, project, data, options) {
  options = options || {};
  data = normalizeDocData_(tpl, project, data, options.record || {});
  var title = String(tpl.TemplateName || '').replace(/Equipment Check List/g, 'Equipment Checklist').toUpperCase();
  var body = '';
  if (tpl.TemplateCode === 'PJ-EQUIP-CHK-001') body = renderEquipmentChecklist_(tpl, project, data, options);
  else if (tpl.TemplateCode === 'PJ-WCR-001' || /work completion/i.test(String(tpl.TemplateName || ''))) body = renderWorkCompletionReport_(tpl, project, data, options);
  else body = renderGenericForm_(tpl, project, data, options);

  return '<div class="a4-root">' +
    a4Style_(options.editable) +
    '<div class="a4-page">' +
      renderDocHeader_(title, tpl, project, data, options) +
      body +
      renderFooter_(data) +
    '</div>' +
    '</div>';
}

function a4Style_(editable) {
  return '<style>' +
