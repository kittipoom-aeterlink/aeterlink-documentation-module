function apiSaveRecord(table, obj) {
  assertTable_(table);
  var rec = writeRow_(table, obj || {}, false);
  audit_('SAVE', table, rec[idField_(table)], '', JSON.stringify(rec));
  return rec;
}

function apiDeleteRecord(table, id, reason) {
  assertTable_(table);
  var rec = findById_(table, id);
  if (!rec) throw new Error('Record not found: ' + id);
  rec.IsDeleted = true;
  writeRow_('RECYCLE_BIN', {RecycleId:uid_('RB'), DateTime:now_(), UserEmail:email_(), TableName:table, RecordId:id, RecordJson:JSON.stringify(rec), Reason:reason || ''}, true);
  var saved = writeRow_(table, rec, false);
  audit_('DELETE', table, id, JSON.stringify(rec), '');
  return saved;
}


function apiSaveDraft(templateCode, projectCode, dataJson, formRecordId) {
  var tpl = findById_('FORM_TEMPLATES', templateCode);
  if (!tpl) throw new Error('Template not found: ' + templateCode);
  var project = getProject_(projectCode);
  var data = parseJson_(dataJson, {});
  var id = formRecordId || uid_('FRM');
  var existing = formRecordId ? findById_('FORM_RECORDS', formRecordId) : null;
  if (existing && String(existing.LockedAfterPdf).toUpperCase() === 'TRUE') {
    throw new Error('Issued documents are locked. Use Start Revision before editing.');
  }
  var docNo = (existing && existing.DocumentNo) || 'Not issued – suffix XXX';
  var row = {
    FormRecordId:id,
    ProjectCode: project.ProjectCode,
    TemplateCode: templateCode,
    DocumentNo: docNo,
    RevisionNo: (existing && existing.RevisionNo) || getSetting_('DEFAULT_REVISION') || '00',
    IssueNo: (existing && existing.IssueNo) || 'XXX',
    Status:'Draft / Not Issued',
    DataJson:JSON.stringify(data),
    DocumentStatus:'Draft',
    LockedAfterPdf:false,
    SubmittedBy:email_(),
    SubmittedAt:now_()
  };
  var saved = writeRow_('FORM_RECORDS', row, false);
  audit_('SAVE_DRAFT','FORM_RECORDS',saved.FormRecordId,'',JSON.stringify(saved));
  return saved;
}

function apiIssueRecord(templateCode, projectCode, dataJson, formRecordId) {
  var tpl = findById_('FORM_TEMPLATES', templateCode);
  if (!tpl) throw new Error('Template not found: ' + templateCode);
  var project = getProject_(projectCode);
  var data = parseJson_(dataJson, {});
  var id = formRecordId || uid_('FRM');
  var existing = formRecordId ? findById_('FORM_RECORDS', formRecordId) : null;
  if (existing && String(existing.LockedAfterPdf).toUpperCase() === 'TRUE') {
    throw new Error('This record has already been issued and locked. Start a revision first.');
  }
  var issueNo = nextIssueNo_(project.ProjectCode, templateCode);
  var revisionNo = (existing && existing.RevisionNo) || getSetting_('DEFAULT_REVISION') || '00';
  var docCode = docCodeForTemplate_(tpl);
  var docNo = project.ProjectCode + '-' + docCode + '-' + issueNo;
  data.DocumentNo = docNo;
  data.IssueNo = issueNo;
  data.RevisionNo = revisionNo;

  var record = writeRow_('FORM_RECORDS', {
    FormRecordId:id,
    ProjectCode:project.ProjectCode,
    TemplateCode:templateCode,
    DocumentNo:docNo,
    RevisionNo:revisionNo,
    IssueNo:issueNo,
    Status:'Issued',
    DataJson:JSON.stringify(data),
    DocumentStatus:'Issued',
    LockedAfterPdf:true,
    SubmittedBy:email_(),
    SubmittedAt:now_()
  }, false);

  var pdf = createPdfForRecord_(record);
  if (pdf && pdf.url) {
    record.PdfUrl = pdf.url;
    writeRow_('FORM_RECORDS', record, false);
  }

  var docId = 'DOC-' + project.ProjectCode + '-' + templateCode + '-' + issueNo;
  var reg = writeRow_('DOCUMENT_REGISTER', {
    DocumentId:docId,
    ProjectCode:project.ProjectCode,
    DocumentCode:docCode,
    DocumentTitle:tpl.TemplateName,
    Revision:revisionNo,
    RevisionNo:revisionNo,
    Status:'Issued',
    Module:tpl.Module,
    FileUrl:pdf.url || '',
    FormRecordId:id,
    ClientStatus:'Not Submitted',
    RequiredForGate:'No',
    SourceTable:'FORM_RECORDS',
    SourceRecordId:id,
    DocumentType:tpl.TemplateCode,
    AutoGenerated:true,
    GeneratedAt:now_(),
    GeneratedBy:email_(),
    DocumentCategory:tpl.DocCategory,
    DocCategory:tpl.DocCategory,
    RequiredByPhase:tpl.PhaseNo
  }, false);

  writeRow_('RECORD_LINKS', {
    LinkId:uid_('LNK'),
    ProjectCode:project.ProjectCode,
    FromTable:'FORM_RECORDS',
    FromRecordId:id,
    ToTable:'DOCUMENT_REGISTER',
    ToRecordId:reg.DocumentId,
    LinkType:'DOCUMENT_REGISTER_AUTO',
    Description:'Auto link from issued A4 form to document register',
    FromId:id,
    ToId:reg.DocumentId
  }, true);

  audit_('ISSUE','FORM_RECORDS',id,'',JSON.stringify(record));
  return {record:record, document:reg, pdf:pdf};
}

function apiStartRevision(formRecordId, reason) {
  var rec = findById_('FORM_RECORDS', formRecordId);
  if (!rec) throw new Error('Record not found: ' + formRecordId);
  if (!reason) throw new Error('Revision reason is required.');
  var rev = String(rec.RevisionNo || '00');
  var n = parseInt(rev, 10);
  if (isNaN(n)) n = 0;
  rec.RevisionNo = String(n + 1).padStart(2, '0');
  rec.Status = 'Draft / Revision';
  rec.DocumentStatus = 'Draft';
  rec.LockedAfterPdf = false;
  rec.RevisionReason = reason;
  writeRow_('FORM_RECORDS', rec, false);
  audit_('START_REVISION','FORM_RECORDS',formRecordId,JSON.stringify({reason:reason}),'');
  return rec;
}

function apiGeneratePdfForRecord(formRecordId) {
  var rec = findById_('FORM_RECORDS', formRecordId);
  if (!rec) throw new Error('Record not found: ' + formRecordId);
  var pdf = createPdfForRecord_(rec);
  if (pdf && pdf.url) {
    rec.PdfUrl = pdf.url;
    writeRow_('FORM_RECORDS', rec, false);
  }
  return pdf;
}

