function v7AssertTable_(table) {
  if (!SCHEMA || !SCHEMA[table]) throw new Error('Unknown table: ' + table);
}

function v7Sheet_(table) {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  return ss ? ss.getSheetByName(table) : null;
}

function v7Headers_(table) {
  var sh = v7Sheet_(table);
  var fallback = (SCHEMA && SCHEMA[table]) ? SCHEMA[table].slice() : [];
  if (!sh || sh.getLastRow() < 1) return fallback;
  var lc = Math.min(Math.max(1, sh.getLastColumn()), Math.max(1, fallback.length, 80), sh.getMaxColumns());
  var row = sh.getRange(1,1,1,lc).getDisplayValues()[0];
  var h = row.map(function(x){ return String(x || '').trim(); }).filter(function(x){ return x !== ''; });
  return h.length ? h : fallback;
}

function v7ReadRows_(table, options) {
  options = options || {};
  var sh = v7Sheet_(table);
  if (!sh) return [];
  var h = v7Headers_(table);
  if (!h.length) return [];
  var lastRow = sh.getLastRow();
  if (lastRow < 2) return [];
  var max = Math.max(1, Math.min(Number(options.maxRows || 2000), 3000));
  var dataRows = lastRow - 1;
  var numRows = Math.min(max, dataRows);
  var startRow = options.fromBottom ? Math.max(2, lastRow - numRows + 1) : 2;
  var lc = Math.min(Math.max(sh.getLastColumn(), h.length), Math.max(h.length, 80));
  lc = Math.min(lc, 120, sh.getMaxColumns());
  var values = sh.getRange(startRow, 1, numRows, lc).getDisplayValues();
  var idxDel = h.indexOf('IsDeleted');
  var idxProject = h.indexOf('ProjectCode');
  var projectCode = String(options.projectCode || '').trim();
  var out = [];
  for (var r = 0; r < values.length; r++) {
    var row = values[r];
    var blank = true;
    for (var c = 0; c < Math.min(row.length, h.length); c++) {
      if (String(row[c] || '').trim() !== '') { blank = false; break; }
    }
    if (blank) continue;
    if (!options.includeDeleted && idxDel >= 0 && String(row[idxDel] || '').toUpperCase() === 'TRUE') continue;
    if (projectCode && idxProject >= 0 && String(row[idxProject] || '').trim() !== projectCode) continue;
    var o = {_row: startRow + r};
    for (var i = 0; i < h.length; i++) if (h[i]) o[h[i]] = row[i] || '';
    out.push(o);
  }
  if (options.fromBottom) out.reverse();
  return out;
}

function v7CountRows_(table) {
  try {
    var sh = v7Sheet_(table);
    if (!sh) return 0;
    return Math.max(0, sh.getLastRow() - 1);
  } catch(e) { return 0; }
}

function v7GetSetting_(key) {
  var rows = v7ReadRows_('SETTINGS', {maxRows:500, includeDeleted:true});
  for (var i=0; i<rows.length; i++) {
    if (String(rows[i].Key || '') === String(key)) return rows[i].Value || '';
  }
  return '';
}

function v7GroupLists_() {
  var out = {};
  v7ReadRows_('LISTS', {maxRows:3000}).forEach(function(r){
    var name = String(r.ListName || '').split('|')[0] || 'General';
    if (!out[name]) out[name] = [];
    out[name].push(r.Value || '');
  });
  return out;
}

function apiPreviewHtml(templateCode, projectCode, dataJson, options) {
