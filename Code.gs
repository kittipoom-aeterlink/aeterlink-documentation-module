/* ---------- 3) Pagination Engine ---------- */
function apiA4LayoutQaV19(templateCode, projectCode, dataJson, formRecordId) {
  var tpl = null;
  try { tpl = findById_('FORM_TEMPLATES', templateCode) || v9DefaultTemplate_(templateCode); } catch(e) {}
  var schema = getDocumentSchemaV19_(tpl || templateCode);
  var data = v19ParseJson_(dataJson, {});
  var metrics = v19EstimatePagination_(schema, data);
  var validation = v19ValidateBySchema_(schema, data, { layoutOnly:true });
  return {
    ok: validation.errors.length === 0,
    schema: schema,
    metrics: metrics,
    errors: validation.errors,
    warnings: validation.warnings,
    info: validation.info.concat(metrics.info || [])
  };
}

function v19EstimatePagination_(schema, data) {
  var table = schema.table || {};
  var arrName = table.arrayName;
  var rows = arrName ? v19ParseArray_(data[arrName]) : [];
  var pages = [];
  if (rows.length) {
    var firstLimit = table.firstPageRows || 16;
    var continuedLimit = table.continuedPageRows || 24;
    var p1 = v19ChunkRowsByWeight_(rows, 0, firstLimit, table.wrapAtChars || 42);
    pages.push({ type:'table-first', start:0, end:p1.end, rows:p1.rows, estimatedWeight:p1.weight });
    var start = p1.end;
    while (start < rows.length) {
      var p = v19ChunkRowsByWeight_(rows, start, continuedLimit, table.wrapAtChars || 42);
      pages.push({ type:'table-continued', start:start, end:p.end, rows:p.rows, estimatedWeight:p.weight });
      start = p.end;
      if (pages.length > 80) break;
    }
  }
  var photoArr = schema.photo && schema.photo.arrayName ? v19ParseArray_(data[schema.photo.arrayName]) : [];
  var per = (schema.photo && schema.photo.photosPerPage) || 2;
  var photoPages = Math.ceil(photoArr.length / per);
  for (var i=0; i<photoPages; i++) {
    pages.push({ type:'photo', start:i*per, end:Math.min((i+1)*per, photoArr.length), rows:Math.min(per, photoArr.length - i*per) });
  }
  return {
    totalPages: Math.max(1, pages.length || 1),
    tableRows: rows.length,
    photoItems: photoArr.length,
    photosPerPage: per,
    pages: pages,
    info: [
      'A4 binding margin: left 18mm / right 11mm / top 10mm / bottom 9mm',
      'Estimated pages: ' + Math.max(1, pages.length || 1),
      'Photo report rule: 1 A4 page = ' + per + ' photos'
    ]
  };
}

function v19ChunkRowsByWeight_(rows, start, maxWeight, wrapAt) {
  var weight = 0;
  var i = start;
  for (; i < rows.length; i++) {
    var w = v19RowWeight_(rows[i], wrapAt);
    if (i > start && weight + w > maxWeight) break;
    weight += w;
  }
  return { end:i, rows:i-start, weight:weight };
}

function v19RowWeight_(row, wrapAt) {
  var maxLen = 0;
  Object.keys(row || {}).forEach(function(k) { maxLen = Math.max(maxLen, String(row[k] == null ? '' : row[k]).length); });
  if (!maxLen) return 1;
  return Math.max(1, Math.ceil(maxLen / Math.max(20, wrapAt || 42)));
}

/* ---------- 4) Validation Engine ---------- */
function apiValidateDocumentV19(templateCode, projectCode, dataJson, formRecordId) {
  var tpl = null;
  try { tpl = findById_('FORM_TEMPLATES', templateCode) || v9DefaultTemplate_(templateCode); } catch(e) {}
  var schema = getDocumentSchemaV19_(tpl || templateCode);
  var data = v19ParseJson_(dataJson, {});
  var validation = v19ValidateBySchema_(schema, data, { projectCode:projectCode, formRecordId:formRecordId });
  var metrics = v19EstimatePagination_(schema, data);
  return {
    ok: validation.errors.length === 0,
    canIssue: validation.errors.length === 0 && (schema.issueRules.allowIssueWithWarnings || validation.warnings.length === 0),
    errors: validation.errors,
    warnings: validation.warnings,
    info: validation.info,
    schema: schema,
    metrics: metrics
  };
}


function v20GetTableCellValue_(row, col, idx, schema) {
  row = row || {};
  col = col || {};
  if (col.autoIndex) return row[col.key] || row['No.'] || row.ItemNo || String((idx || 0) + 1);
  if (v19HasValue_(row[col.key])) return row[col.key];
  var aliases = col.aliases || [];
  for (var i = 0; i < aliases.length; i++) {
    if (v19HasValue_(row[aliases[i]])) return row[aliases[i]];
  }
  return row[col.key];
}

function v19ValidateBySchema_(schema, data, ctx) {
  ctx = ctx || {};
  var errors = [];
  var warnings = [];
  var info = [];
  var required = schema.requiredFields || [];
  required.forEach(function(k) {
    if (!v19HasValue_(data[k])) errors.push('Required field is missing: ' + k);
  });
  (schema.softRequiredFields || []).forEach(function(k) {
    if (!v19HasValue_(data[k])) warnings.push('Recommended field is blank: ' + k);
  });
  var table = schema.table || {};
  if (table.arrayName) {
    var rows = v19ParseArray_(data[table.arrayName]);
    if (!rows.length) errors.push('Main table has no rows: ' + table.arrayName);
    var cols = table.columns || [];
    rows.forEach(function(row, idx) {
      cols.forEach(function(col) {
        var val = v20GetTableCellValue_(row, col, idx, schema);
        if (col.required && !v19HasValue_(val)) warnings.push('Row ' + (idx+1) + ' missing required table value: ' + col.label);
        if (col.type === 'number' && v19HasValue_(val) && isNaN(Number(String(val).replace(/,/g,'')))) warnings.push('Row ' + (idx+1) + ' has non-numeric ' + col.label + ': ' + val);
        if (col.allowed && v19HasValue_(val) && col.allowed.indexOf(String(val).trim()) < 0) warnings.push('Row ' + (idx+1) + ' has non-standard ' + col.label + ': ' + val);
      });
      if (String(row.Status || '').toLowerCase() === 'done' && !v19HasValue_(row.Qty) && schema.templateCode === 'PJ-WCR-001') {
        warnings.push('Row ' + (idx+1) + ' status is Done but Qty is blank.');
      }
      if (String(v20GetTableCellValue_(row, {key:'Condition', aliases:['InstallationCondition']}, idx, schema) || '').toUpperCase() === 'OK' && !v19HasValue_(v20GetTableCellValue_(row, {key:'InstalledQty', aliases:['InstalledQuantity']}, idx, schema)) && schema.templateCode === 'PJ-EQUIP-CHK-001') {
        warnings.push('Equipment row ' + (idx+1) + ' condition is OK but Installed Qty is blank.');
      }
    });
  }
  if (schema.photo && schema.photo.arrayName) {
    var photos = v19ParseArray_(data[schema.photo.arrayName]);
    if (schema.photo.required && !photos.length) errors.push('Photo report is required but no photo items found.');
    photos.forEach(function(p, i) {
      if (!v19HasValue_(p.ImageData) && !v19HasValue_(p.ImageKey)) warnings.push('Photo item ' + (p.ItemNo || (i+1)) + ' has no image.');
      (schema.photo.requiredFields || []).forEach(function(k) { if (!v19HasValue_(p[k])) warnings.push('Photo item ' + (i+1) + ' missing ' + k); });
    });
  }
  if (errors.length === 0) info.push('Document can be issued. Warnings should be reviewed before sending to client.');
  info.push('Schema: ' + schema.templateCode + ' / Layout: ' + schema.layoutType);
  return { errors: errors, warnings: warnings, info: info };
}

/* ---------- 5) AI Assist Layer ---------- */
function apiAIAssistDocumentV19(templateCode, projectCode, dataJson, mode) {
  var tpl = null;
  try { tpl = findById_('FORM_TEMPLATES', templateCode) || v9DefaultTemplate_(templateCode); } catch(e) {}
  var schema = getDocumentSchemaV19_(tpl || templateCode);
  var data = v19ParseJson_(dataJson, {});
  var validation = apiValidateDocumentV19(templateCode, projectCode, dataJson, '');
  var local = v19LocalAIAssist_(schema, data, validation, mode || 'review');
  return {
    ok: true,
    mode: mode || 'review',
    aiMode: 'local-rule-based',
    externalAiConfigured: false,
    schema: schema,
    suggestions: local,
    validation: validation,
    note: 'Local AI Assist is enabled. Optional external AI can be connected later via Apps Script properties without changing the document layout engine.'
  };
}

function v19LocalAIAssist_(schema, data, validation, mode) {
  var links = schema.autoLinks || [];
  var remarks = '';
  if (schema.templateCode === 'PJ-WCR-001') {
    remarks = 'Work completed as per approved scope. Supporting completion status and photo evidence are attached for client review and handover record.';
  } else if (schema.templateCode === 'PJ-EQUIP-CHK-001') {
    remarks = 'Equipment installation checklist reviewed against site installation records and reference documents. Items marked OK are ready for client review.';
  } else {
    remarks = 'Document prepared for project record and client review according to AETERLINK document control workflow.';
  }
  var missing = (validation.errors || []).concat(validation.warnings || []);
  var clientStatus = validation.errors && validation.errors.length ? 'Not Ready' : (validation.warnings && validation.warnings.length ? 'Review Required' : 'Ready for Submittal');
  return {
    suggestedClientStatus: clientStatus,
    suggestedRemarks: remarks,
    suggestedLinkedModules: links,
    missingInformationSummary: missing.length ? missing.slice(0, 12) : ['No critical missing information found.'],
    wordingSuggestions: v19WordingSuggestions_(schema, data),
    nextActions: validation.errors && validation.errors.length ? ['Fix required fields before Issue / Send.'] : ['Review warnings.', 'Save draft.', 'Issue document number.', 'Create client submittal if required.']
  };
}

function v19WordingSuggestions_(schema, data) {
  var out = [];
  if (data.GeneralRemarks && String(data.GeneralRemarks).length > 220) out.push('Remarks are long. Consider splitting into bullet points or moving details to attachment/reference document.');
  if (schema.templateCode === 'PJ-WCR-001' && data.WorkType && String(data.WorkType).indexOf('/') >= 0) out.push('Work Type contains multiple scopes. Keep slash-separated wording consistent across WCR pages.');
  if (!out.length) out.push('No wording issue detected by local assist.');
  return out;
}

