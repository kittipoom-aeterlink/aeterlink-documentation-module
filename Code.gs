/* ============================================================
 * V10 ISSUE FIX PATCH — appended overrides
 * Purpose:
 *  - Fix client error: Cannot read properties of null (reading 'record')
 *  - Return JSON-safe plain objects to google.script.run
 *  - Run document number automatically when Issue / Send
 *  - Do not generate heavy PDF during Issue by default; use Print/PDF button
 *  - Keep Google Sheet schema unchanged
 * ============================================================ */

function setupDocumentationModuleV10() {
  var h = apiDocumentModuleV10Health();
  try { setSetting_('APP_VERSION', 'V10_ISSUE_FIX', 'Current webapp patch version'); } catch(e) {}
  return h;
}

function apiDocumentModuleV10Health() {
  var base = {};
  try { base = apiDocumentModuleV9Health ? apiDocumentModuleV9Health() : {}; } catch(e) { base = {}; }
  base.ok = true;
  base.version = 'V10_ISSUE_FIX_NO_SHEET_CHANGE';
  base.issueFix = 'apiIssueRecord returns JSON-safe object and skips heavy auto-PDF by default';
  base.autoNumberFormat = '<ProjectCode>-<DocumentCode>-001';
  base.pdfOnIssue = String(getSetting_('AUTO_PDF_ON_ISSUE') || 'FALSE').toUpperCase() === 'TRUE';
  return base;
}

function v10SafePlain_(obj) {
  if (obj === null || obj === undefined) return obj;
  if (Object.prototype.toString.call(obj) === '[object Date]') {
    try { return Utilities.formatDate(obj, tz_ ? tz_() : 'Asia/Bangkok', 'yyyy-MM-dd HH:mm:ss'); } catch(e) { return String(obj); }
  }
  if (Array.isArray(obj)) return obj.map(v10SafePlain_);
  if (typeof obj === 'object') {
    var out = {};
    Object.keys(obj).forEach(function(k){
      var v = obj[k];
      if (typeof v === 'function') return;
      if (v === undefined) v = '';
      out[k] = v10SafePlain_(v);
    });
    return out;
  }
  return obj;
}

function v10TemplateSafe_(templateCode) {
  var tpl = null;
  try { tpl = findById_('FORM_TEMPLATES', templateCode); } catch(e) { tpl = null; }
  if (!tpl && typeof v9DefaultTemplate_ === 'function') tpl = v9DefaultTemplate_(templateCode);
  if (!tpl && templateCode) tpl = {TemplateCode:templateCode, TemplateName:String(templateCode), Module:'Documentation Control', PhaseNo:'', DocCategory:''};
  return tpl;
}

function v10ProjectSafe_(projectCode) {
  if (typeof v9GetProjectSafe_ === 'function') return v9GetProjectSafe_(projectCode);
  try { return getProject_(projectCode); } catch(e) {}
  return {ProjectCode:projectCode || 'ATL-LKL-001', ProjectName:'Lotus’s Klong Luang', Client:'MKY', MainContractor:'KYOUEI / SAAN'};
}

function v10DocCodeForTemplate_(tpl) {
  try { return docCodeForTemplate_(tpl); } catch(e) {}
  return (tpl && tpl.TemplateCode) || 'DOC';
}

function v10NextIssueNo_(projectCode, templateCode, docCode) {
  var max = 0;
  function scanNum(v) {
    var s = String(v || '');
    var m = s.match(/(?:^|-)(\d{3,})(?:$|\D)/);
    if (m) max = Math.max(max, parseInt(m[1], 10) || 0);
  }
  try {
    var rows = readRows_('FORM_RECORDS', {projectCode:projectCode, includeDeleted:false, maxRows:10000});
    rows.forEach(function(r){
      if (String(r.TemplateCode || '') !== String(templateCode || '')) return;
      scanNum(r.IssueNo);
      scanNum(r.DocumentNo);
    });
  } catch(e) {}
  try {
    var docs = readRows_('DOCUMENT_REGISTER', {projectCode:projectCode, includeDeleted:false, maxRows:10000});
    docs.forEach(function(d){
      if (docCode && String(d.DocumentCode || '') !== String(docCode || '')) return;
      scanNum(d.SubmissionNo);
      scanNum(d.DocumentNo);
      scanNum(d.DocumentId);
    });
  } catch(e2) {}
  return String(max + 1).padStart(3, '0');
}

function v10CreatePdfIfEnabled_(record) {
  var enabled = String(getSetting_('AUTO_PDF_ON_ISSUE') || 'FALSE').toUpperCase() === 'TRUE';
  if (!enabled) return {skipped:true, reason:'AUTO_PDF_ON_ISSUE is FALSE. Use Print/PDF button to export.'};
  try {
    var pdf = createPdfForRecord_(record);
    return pdf || {skipped:true, reason:'PDF generator returned empty result'};
  } catch(e) {
    return {skipped:true, error:String(e && e.message ? e.message : e)};
  }
}

function apiIssueRecord(templateCode, projectCode, dataJson, formRecordId) {
  var lock = null;
  try { lock = LockService.getScriptLock(); lock.waitLock(20000); } catch(lockErr) { lock = null; }
  try {
    var tpl = v10TemplateSafe_(templateCode);
    if (!tpl) throw new Error('Template not found: ' + templateCode);
    var project = v10ProjectSafe_(projectCode);
    if (!project.ProjectCode) project.ProjectCode = projectCode || getActiveProjectCode_() || 'ATL-LKL-001';
    var data = parseJson_(dataJson, {});
    var id = formRecordId || uid_('FRM');
    var existing = formRecordId ? findById_('FORM_RECORDS', formRecordId) : null;
    if (existing && String(existing.LockedAfterPdf).toUpperCase() === 'TRUE') {
      throw new Error('This record has already been issued and locked. Please click Start Revision before editing.');
    }

    var revisionNo = (existing && existing.RevisionNo) || data.RevisionNo || getSetting_('DEFAULT_REVISION') || '00';
    var docCode = v10DocCodeForTemplate_(tpl);
    var issueNo = v10NextIssueNo_(project.ProjectCode, templateCode, docCode);
    var docNo = project.ProjectCode + '-' + docCode + '-' + issueNo;
    var issueDate = todayLong_ ? todayLong_() : Utilities.formatDate(new Date(), 'Asia/Bangkok', 'd MMMM yyyy');

    data.ProjectCode = project.ProjectCode;
    data.ProjectName = data.ProjectName || data.ProjectNameSite || project.ProjectName || '';
    data.ProjectNameSite = data.ProjectNameSite || data.ProjectName || project.ProjectName || '';
    data.ClientName = data.ClientName || data.Client || project.Client || '';
    data.Client = data.Client || data.ClientName || project.Client || '';
    data.MainContractor = data.MainContractor || project.MainContractor || getSetting_('MAIN_CONTRACTOR_DEFAULT') || '';
    data.DocumentNo = docNo;
    data.IssueNo = issueNo;
    data.RevisionNo = revisionNo;
    data.Date = issueDate;
    if (String(templateCode) === 'PJ-WCR-001' || /work completion/i.test(String(tpl.TemplateName || ''))) {
      data.CompletionDate = data.CompletionDate || issueDate;
    }

    var record = writeRow_('FORM_RECORDS', {
      FormRecordId:id,
      ProjectCode:project.ProjectCode,
      TemplateCode:templateCode,
      DocumentNo:docNo,
      RevisionNo:revisionNo,
      IssueNo:issueNo,
      Status:'Issued',
      DataJson:JSON.stringify(data),
      DocumentStatus:'Issued',
      LockedAfterPdf:true,
      SubmittedBy:email_(),
      SubmittedAt:now_()
    }, false);

    var pdf = v10CreatePdfIfEnabled_(record);
    if (pdf && pdf.url) {
      record.PdfUrl = pdf.url;
      record = writeRow_('FORM_RECORDS', record, false);
    }

    var docId = 'DOC-' + project.ProjectCode + '-' + docCode + '-' + issueNo;
    var reg = writeRow_('DOCUMENT_REGISTER', {
      DocumentId:docId,
      ProjectCode:project.ProjectCode,
      DocumentCode:docCode,
      DocumentTitle:tpl.TemplateName || templateCode,
      Revision:revisionNo,
      RevisionNo:revisionNo,
      Status:'Issued',
      Module:tpl.Module || '',
      FileUrl:(pdf && pdf.url) || '',
      FormRecordId:id,
      ClientStatus:'Not Submitted',
      RequiredForGate:'No',
      SourceTable:'FORM_RECORDS',
      SourceRecordId:id,
      DocumentType:tpl.TemplateCode || templateCode,
      AutoGenerated:true,
      GeneratedAt:now_(),
      GeneratedBy:email_(),
      DocumentCategory:tpl.DocCategory || '',
      DocCategory:tpl.DocCategory || '',
      RequiredByPhase:tpl.PhaseNo || '',
      SubmissionNo:issueNo
    }, false);

    writeRow_('RECORD_LINKS', {
      LinkId:uid_('LNK'),
      ProjectCode:project.ProjectCode,
      FromTable:'FORM_RECORDS',
      FromRecordId:id,
      ToTable:'DOCUMENT_REGISTER',
      ToRecordId:reg.DocumentId,
      LinkType:'DOCUMENT_REGISTER_AUTO',
      Description:'Auto link from issued A4 form to document register',
      FromId:id,
      ToId:reg.DocumentId
    }, true);

    try { audit_('ISSUE','FORM_RECORDS',id,'V10 auto issue number ' + docNo,JSON.stringify(record)); } catch(ae) {}
    return v10SafePlain_({ok:true, record:record, document:reg, pdf:pdf, issueNo:issueNo, documentNo:docNo});
  } finally {
    try { if (lock) lock.releaseLock(); } catch(e) {}
  }
}

function apiFindLatestIssuedRecordV10(templateCode, projectCode) {
  var rows = [];
  try { rows = readRows_('FORM_RECORDS', {projectCode:projectCode, includeDeleted:false, maxRows:10000}); } catch(e) { rows = []; }
  rows = rows.filter(function(r){ return String(r.TemplateCode || '') === String(templateCode || '') && String(r.Status || '').toLowerCase().indexOf('issued') >= 0; });
  rows.sort(function(a,b){
    var an = parseInt(String(a.IssueNo || '').replace(/\D/g,''),10) || 0;
    var bn = parseInt(String(b.IssueNo || '').replace(/\D/g,''),10) || 0;
    return bn - an;
  });
  return v10SafePlain_({ok:true, record:rows[0] || null});
}

function apiGeneratePdfForRecord(formRecordId) {
  var rec = findById_('FORM_RECORDS', formRecordId);
  if (!rec) throw new Error('Record not found: ' + formRecordId);
  var pdf = createPdfForRecord_(rec);
  if (pdf && pdf.url) {
    rec.PdfUrl = pdf.url;
    writeRow_('FORM_RECORDS', rec, false);
    try {
      var docs = readRows_('DOCUMENT_REGISTER', {projectCode:rec.ProjectCode, includeDeleted:false, maxRows:10000});
      docs.forEach(function(d){
        if (String(d.FormRecordId || '') === String(formRecordId || '')) {
          d.FileUrl = pdf.url;
          writeRow_('DOCUMENT_REGISTER', d, false);
        }
      });
    } catch(e) {}
  }
  return v10SafePlain_(pdf || {});
}

function apiGeneratePdfFromFormRecord(formRecordId) {
  var pdf = apiGeneratePdfForRecord(formRecordId);
  return v10SafePlain_({ok:true, url:(pdf && pdf.url) || '', fileId:(pdf && (pdf.fileId || pdf.id)) || '', pdf:pdf});
}

