function apiIssueRecord(templateCode, projectCode, dataJson, formRecordId) {
  var tpl = findById_('FORM_TEMPLATES', templateCode) || v9DefaultTemplate_(templateCode);
  if (!tpl) throw new Error('Template not found: ' + templateCode);
  var project = v9GetProjectSafe_(projectCode);
  var data = parseJson_(dataJson, {});
  var id = formRecordId || uid_('FRM');
  var existing = formRecordId ? findById_('FORM_RECORDS', formRecordId) : null;
  if (existing && String(existing.LockedAfterPdf).toUpperCase() === 'TRUE') {
    throw new Error('This record has already been issued and locked. Start a revision first.');
  }

  var issueNo = nextIssueNo_(project.ProjectCode, templateCode);
  var revisionNo = (existing && existing.RevisionNo) || data.RevisionNo || getSetting_('DEFAULT_REVISION') || '00';
  var docCode = docCodeForTemplate_(tpl);
  var docNo = project.ProjectCode + '-' + docCode + '-' + issueNo;
  var issueDate = todayLong_();

  data.DocumentNo = docNo;
  data.IssueNo = issueNo;
  data.RevisionNo = revisionNo;
  data.Date = issueDate;
  if (templateCode === 'PJ-WCR-001' || /work completion/i.test(String(tpl.TemplateName || ''))) {
    data.CompletionDate = data.CompletionDate || issueDate;
  }

  var record = writeRow_('FORM_RECORDS', {
    FormRecordId:id,
    ProjectCode:project.ProjectCode,
    TemplateCode:templateCode,
    DocumentNo:docNo,
    RevisionNo:revisionNo,
    IssueNo:issueNo,
    Status:'Issued',
    DataJson:JSON.stringify(data),
    DocumentStatus:'Issued',
    LockedAfterPdf:true,
    SubmittedBy:email_(),
    SubmittedAt:now_()
  }, false);

  var pdf = createPdfForRecord_(record);
  if (pdf && pdf.url) {
    record.PdfUrl = pdf.url;
    writeRow_('FORM_RECORDS', record, false);
  }

  var docId = 'DOC-' + project.ProjectCode + '-' + docCode + '-' + issueNo;
  var reg = writeRow_('DOCUMENT_REGISTER', {
    DocumentId:docId,
    ProjectCode:project.ProjectCode,
    DocumentCode:docCode,
    DocumentTitle:tpl.TemplateName,
    Revision:revisionNo,
    RevisionNo:revisionNo,
    Status:'Issued',
    Module:tpl.Module,
    FileUrl:(pdf && pdf.url) || '',
    FormRecordId:id,
    ClientStatus:'Not Submitted',
    RequiredForGate:'No',
    SourceTable:'FORM_RECORDS',
    SourceRecordId:id,
    DocumentType:tpl.TemplateCode,
    AutoGenerated:true,
    GeneratedAt:now_(),
    GeneratedBy:email_(),
    DocumentCategory:tpl.DocCategory,
    DocCategory:tpl.DocCategory,
    RequiredByPhase:tpl.PhaseNo,
    SubmissionNo:issueNo
  }, false);

  writeRow_('RECORD_LINKS', {
    LinkId:uid_('LNK'),
    ProjectCode:project.ProjectCode,
    FromTable:'FORM_RECORDS',
    FromRecordId:id,
    ToTable:'DOCUMENT_REGISTER',
    ToRecordId:reg.DocumentId,
    LinkType:'DOCUMENT_REGISTER_AUTO',
    Description:'Auto link from issued A4 form to document register',
    FromId:id,
    ToId:reg.DocumentId
  }, true);

  audit_('ISSUE','FORM_RECORDS',id,'V9 auto issue number ' + docNo,JSON.stringify(record));
